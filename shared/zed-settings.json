// Zed settings — managed by chezmoi. Source of truth for ~/.config/zed/settings.json.
// Sister file: ~/dev/personal/installfest/shared/vscode-user-settings.json (VS Code + Cursor).
//
// === Parity goal: Zed mirrors VS Code/Cursor wherever the schema permits ===
// Translatable keys (font, format_on_save, autosave, language formatters, watcher
// excludes, terminal, theme, tsserver memory) are kept in sync.
//
// Items present in vscode-user-settings.json with NO Zed equivalent — owned by
// VS Code only, not a parity gap:
//   • editor.bracketPairColorization / editor.guides.bracketPairs (Zed: theme-driven)
//   • editor.suggestSelection / editor.accessibilitySupport
//   • diffEditor.ignoreTrimWhitespace / editor.unicodeHighlight.*
//   • files.trimFinalNewlines / files.eol / explorer.confirm*
//   • eslint.run / eslint.format.enable / prettier.requireConfig (Zed: LSP-driven)
//   • typescript.tsdk / *.updateImportsOnFileMove.enabled (Zed: tsserver auto-resolved)
//   • git.confirmSync / git.autofetch / git.enableSmartCommit (Zed: minimal git config)
//   • All extension settings — gitlens.*, cursor.*, claudeCode.*, viraTheme.*,
//     markdown-preview-enhanced.*, liveServer.*, hediet.*
//   • terminal.integrated.shellArgs.osx / .env.{linux,osx} (Zed: inherits parent env)
//   • terminal.integrated.gpuAcceleration (Zed: GPU rendering is default)
//   • remote.SSH.* / chat.viewSessions.* / window.commandCenter
//
// Bicep: auto-installed extension uses the `bicep` CLI from Homebrew.
// Live-reload static dev: install `live-server` globally (see run_once_install-packages.sh.tmpl).
{
  "project_panel": {
    "dock": "left"
  },
  "cli_default_open_behavior": "new_window",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },

  // === Editor ===
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "buffer_font_features": { "calt": true },
  "ui_font_family": "JetBrainsMono Nerd Font",
  "ui_font_size": 14,
  "format_on_save": "on",
  "format_on_paste": false,
  "formatter": "prettier",
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "preferred_line_length": 100,
  "wrap_guides": [100],
  "show_wrap_guides": true,

  // === Theme ===
  // One Hunter Vercel matches the Ghostty + tmux palette already in this
  // dotfiles repo (home/dot_config/ghostty/themes/One-Hunter-Vercel).
  // The "one-hunter" extension is auto-installed below; ships 6 variants:
  //   One Hunter Light, Classic, Flexokit Light, Flexoki Dark, Material, Vercel.
  "theme": {
    "mode": "dark",
    "light": "One Hunter Light",
    "dark": "One Hunter Vercel"
  },

  // === Git ===
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": { "enabled": true, "delay_ms": 600 }
  },

  // === Auto-install required extensions ===
  //   bicep      — ARM template authoring (binary at ~/.local/bin/bicep)
  //   one-hunter — One Hunter theme family (incl. One Hunter Vercel)
  "auto_install_extensions": {
    "bicep": true,
    "one-hunter": true
  },

  // === AI: Edit Predictions (Zed's native copilot) ===
  // Free with a Zed account; sign in via Cmd+Shift+P → "zed: sign in".
  // Set to "copilot" for GitHub Copilot, "supermaven" for Supermaven.
  "features": {
    "edit_predictions_provider": "zed"
  },
  "show_edit_predictions": true,

  // === AI: Agent panel + inline edits (Cmd+I) ===
  // (Renamed from `assistant` → `agent` in Zed 0.158+; `assistant.version` and
  // `language_models.anthropic.version` were deprecated and removed.)
  // Anthropic enabled — same key you use for Claude Code.
  // Zed prompts for ANTHROPIC_API_KEY on first use (or reads from env).
  // Pick the active model from the agent panel dropdown — Zed's known-
  // models list updates per release, so we don't pin a default here.
  "agent": {
    "enabled": true,
    "button": true
  },
  "language_models": {
    "anthropic": {}
  },

  // === Context Servers (MCP) ===
  // Zed connects to MCP servers the same way Claude Code does. To wire one,
  // add an entry below — e.g. beads, github, sentry — using the same command
  // and env you use in ~/.claude/mcp_servers.json. Left empty for now to
  // avoid forcing a configuration; populate as needed.
  "context_servers": {},

  // === Per-language formatters / settings ===
  "languages": {
    "TypeScript": { "formatter": "prettier", "format_on_save": "on" },
    "TSX": { "formatter": "prettier", "format_on_save": "on" },
    "JavaScript": { "formatter": "prettier", "format_on_save": "on" },
    "JSX": { "formatter": "prettier", "format_on_save": "on" },
    "JSON": { "formatter": "prettier", "format_on_save": "on" },
    "JSONC": { "formatter": "prettier", "format_on_save": "on" },
    "YAML": { "formatter": "prettier", "format_on_save": "on" },
    "Markdown": { "formatter": "prettier", "format_on_save": "on", "soft_wrap": "preferred_line_length" },
    "HTML": { "formatter": "prettier", "format_on_save": "on" },
    "CSS": { "formatter": "prettier", "format_on_save": "on" },
    "Bicep": { "format_on_save": "on" }
  },

  // === LSP server config ===
  "lsp": {
    // Bicep — extension wires this automatically; explicit fallback in case
    // the extension fails to load. Binary lives at ~/.local/bin/bicep
    // (symlinked from ~/.azure/bin/bicep, installed via az bicep install).
    "bicep-langserver": {
      "binary": {
        "path": "bicep",
        "arguments": ["langserver"]
      }
    },

    // TypeScript — bound memory at 1.5 GB to keep remote-server resident set
    // under control on t3 turbo monorepos. Without this, tsserver routinely
    // balloons to 2-3 GB on projects with 10+ packages sharing types (oo,
    // tc, etc.). Mirrors the prior Cursor setting (typescript.tsserver
    // .maxTsServerMemory: 1536). includePackageJsonAutoImports is the most
    // expensive auto-feature in tsserver — disabling it saves ~30% memory
    // and removes auto-import suggestions from package.json scanning (Zed's
    // own auto-import via tree-sitter still works for imports already in
    // the project).
    "typescript-language-server": {
      "initialization_options": {
        "maxTsServerMemory": 1536,
        // Disable @types/* auto-fetch — irrelevant in TS-first monorepos and a
        // measurable CPU cost on cold start. Project still resolves declared
        // dependencies normally; this only stops the implicit ATA scan.
        "disableAutomaticTypingAcquisition": true,
        "preferences": {
          "includePackageJsonAutoImports": "off"
        }
      }
    }
  },

  // === File scan / search excludes ===
  // Mirrors the Cursor watcher/search excludes — keeps file tree fast on T3 monorepos.
  //
  // Linux dev-host trees added 2026-05-06 after fs_watcher rescan-loop diagnosis
  // (514% CPU + 16GB rescan logs). Without these, opening any workspace whose
  // file_scan reaches into $HOME causes the watcher to walk Steam runtimes,
  // NuGet/.dotnet caches, and Dolt git-remote-cache pack dirs — saturating the
  // inotify event queue and producing a "lost sync → rescan → re-arm → overflow"
  // feedback loop. Excluding **/openspec/changes/archive trades project-search
  // coverage of historical proposals for watcher stability; use ripgrep from a
  // terminal if you ever need to grep archives.
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/.next",
    "**/.turbo",
    "**/.cursor-server",
    "**/.vscode-server",
    "**/.zed-server",
    "**/.cargo",
    "**/.cache",
    "**/.npm",
    "**/.bun",
    "**/.pnpm-store",
    "**/dist",
    "**/build",
    "**/.expo",
    // Linux dev-host trees — see header comment above.
    "**/.steam",
    "**/Steam",
    "**/.nuget",
    "**/.dotnet",
    "**/.azure",
    // Dolt git-remote-cache (pack-shaped object dirs in beads-managed repos).
    "**/.beads/embeddeddolt",
    // OpenSpec archives — hundreds of historical proposals per project.
    "**/openspec/changes/archive"
  ],

  // === Terminal (integrated) ===
  // Mirrors VS Code's terminal.integrated.* settings where Zed has equivalents.
  // Inherits zsh + env from login shell ("system" picks up parent shell).
  "terminal": {
    "shell": "system",
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 13,
    "working_directory": "current_project_directory",
    "copy_on_select": true,
    "blinking": "off",
    "button": true
  },

  // === ESLint fix-on-save (parity with VS Code editor.codeActionsOnSave) ====
  "code_actions_on_format": {
    "source.fixAll.eslint": true
  },

  // === Misc ===
  "vim_mode": false,
  // Mirrors VS Code files.autoSave: "afterDelay". The bare-string form
  // `"after_delay"` was deprecated — now must be an object with milliseconds.
  // Use `"off"` if you want explicit Cmd+S only.
  "autosave": { "after_delay": { "milliseconds": 1000 } },
  "restore_on_startup": "last_session",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "tabs": { "git_status": true, "file_icons": true }
}
