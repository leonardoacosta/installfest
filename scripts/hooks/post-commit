#!/bin/sh
#
# post-commit — local deploy (also symlinked as post-merge)
#
# 1. Import beads changes (idempotent, safe on commit and merge)
# 2. Deploy chezmoi dotfiles

# --- beads import ---
if command -v bd >/dev/null 2>&1; then
    BEADS_DIR=""
    if git rev-parse --git-dir >/dev/null 2>&1; then
        if [ "$(git rev-parse --git-dir)" != "$(git rev-parse --git-common-dir)" ]; then
            MAIN_REPO_ROOT="$(dirname "$(git rev-parse --git-common-dir)")"
            [ -d "$MAIN_REPO_ROOT/.beads" ] && BEADS_DIR="$MAIN_REPO_ROOT/.beads"
        else
            [ -d .beads ] && BEADS_DIR=".beads"
        fi
    fi

    if [ -n "$BEADS_DIR" ]; then
        if [ -f "$BEADS_DIR/metadata.json" ]; then
            if grep -q '"backend"[[:space:]]*:[[:space:]]*"dolt"' "$BEADS_DIR/metadata.json" 2>/dev/null; then
                BEADS_DIR=""
            fi
        fi
        if [ -n "$BEADS_DIR" ] && [ -f "$BEADS_DIR/issues.jsonl" ]; then
            bd import -i "$BEADS_DIR/issues.jsonl" >/dev/null 2>&1 || true
        fi
    fi
fi

# --- chezmoi apply ---
if command -v chezmoi >/dev/null 2>&1; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
    CHEZMOI_SOURCE="$(chezmoi source-path 2>/dev/null)"
    # .chezmoiroot makes source-path return home/ subdir — match prefix
    case "$CHEZMOI_SOURCE" in "$REPO_ROOT"*)
        # init --apply (not plain apply): `apply` alone never re-renders
        # .chezmoi.toml.tmpl, so a commit that changes $theme (or any other
        # [data] value) would deploy against a stale cached config otherwise.
        if chezmoi init --source="$REPO_ROOT" --apply --no-tty 2>/dev/null; then
            echo "chezmoi: applied dotfiles"
        else
            echo "chezmoi: apply failed (run 'chezmoi apply' manually)" >&2
        fi
        ;; esac
fi

# --- ZSA Voyager firmware (self-gating per-hostname, backgrounded) -----
# Mac: notice a staged .bin in Downloads and drive the notify/flash-poll.
# Homelab: poll Oryx for a layout change and build+ship if there is one.
REPO_ROOT="${REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null)}"
if [ -n "$REPO_ROOT" ]; then
    if [ -x "$REPO_ROOT/scripts/hooks/zsa-firmware-check.sh" ]; then
        nohup "$REPO_ROOT/scripts/hooks/zsa-firmware-check.sh" </dev/null >/dev/null 2>&1 &
        disown 2>/dev/null || true
    fi
    if [ -x "$REPO_ROOT/scripts/hooks/zsa-firmware-build.sh" ]; then
        REPO_ROOT="$REPO_ROOT" nohup "$REPO_ROOT/scripts/hooks/zsa-firmware-build.sh" </dev/null >/dev/null 2>&1 &
        disown 2>/dev/null || true
    fi
fi

exit 0
