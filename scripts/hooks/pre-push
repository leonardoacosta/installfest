#!/bin/sh
#
# pre-push — bidirectional remote deploy
#
# After push completes, SSH to the OTHER machine and pull + apply.
# Background with sleep to let push finish first.
#
# Logs land on the REMOTE machine at ~/.local/state/if-deploy.log so silent
# failures (like a bad Brewfile entry that aborts brew bundle) stop being
# invisible. Tail with: ssh <peer> 'tail -50 ~/.local/state/if-deploy.log'

# Guard: skip if triggered by remote deploy SSH
[ "$IF_REMOTE_DEPLOY" = "1" ] && exit 0

deploy_remote() {
    target="$1"
    # Capture pre-deploy SHA so remote-apply.sh can diff raycast-scripts/
    # and notify (Mac-only) when scripts changed in this deploy.
    (sleep 2 && IF_REMOTE_DEPLOY=1 ssh "$target" \
        "cd ~/dev/if && \
         pre_sha=\$(git rev-parse HEAD 2>/dev/null) && \
         git fetch origin main -q && git reset --hard origin/main -q && \
         bash scripts/hooks/remote-apply.sh \"\$pre_sha\"" &) 2>/dev/null
}

# Use the SHORT hostname (hostname -s) so a ".local" suffix never breaks the
# match, and accept both the canonical and the macOS-restore-default Mac names
# (a fresh restore renames the Mac to "Leonardos-MacBook-Pro").
case "$(hostname -s)" in
    homelab)
        deploy_remote mac ;;
    leonardoacostas-MacBook-Pro|Leonardos-MacBook-Pro)
        deploy_remote homelab ;;
esac

exit 0
