#!/bin/sh
#
# pre-commit — runs before git commit
#
# 0. Secret scan (blocks the commit on findings).
# 1. check.sh baseline — zsh/sh syntax, template render, shellcheck, terraform
#    validate (blocks the commit on any failure; if-ev7).
# 2. Regenerate Raycast scripts when projects.toml or generator is staged
#    (auto-stages output so commits always contain matching artifacts).
# 3. Flush beads pending changes to JSONL.

# === 0. Secret scan (blocks commit on findings) ===
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -n "$REPO_ROOT" ] && [ -x "$REPO_ROOT/.githooks/pre-commit" ]; then
    "$REPO_ROOT/.githooks/pre-commit" || exit 1
fi

# === 1. check.sh baseline (blocks commit on failure; if-ev7) ===
# NOTE: no `|| true` — a failing check MUST block the commit. ~2.3s warm.
if [ -n "$REPO_ROOT" ] && [ -x "$REPO_ROOT/scripts/check.sh" ]; then
    if ! "$REPO_ROOT/scripts/check.sh" >/tmp/if-precommit-check.$$ 2>&1; then
        echo "Error: scripts/check.sh failed — fix before committing" >&2
        cat /tmp/if-precommit-check.$$ >&2
        rm -f /tmp/if-precommit-check.$$
        exit 1
    fi
    rm -f /tmp/if-precommit-check.$$
fi

# === 2. Raycast script regeneration ===
# Trigger only when the source-of-truth files are staged. Fail the commit
# if generation errors so drift never lands in main.
if git diff --cached --name-only 2>/dev/null | grep -qE '^(home/projects\.toml|scripts/generate-raycast\.sh)$'; then
    REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
    if [ -n "$REPO_ROOT" ] && [ -x "$REPO_ROOT/scripts/generate-raycast.sh" ]; then
        if ! command -v python3 >/dev/null 2>&1; then
            echo "Error: python3 required by generate-raycast.sh — install python3 to commit" >&2
            exit 1
        fi
        if ! bash "$REPO_ROOT/scripts/generate-raycast.sh" >/dev/null 2>&1; then
            echo "Error: generate-raycast.sh failed — fix before committing" >&2
            echo "  Run manually: bash scripts/generate-raycast.sh" >&2
            exit 1
        fi
        # Auto-stage regenerated scripts (only in regular repo, not worktrees,
        # to avoid surprise stages in detached states).
        if [ "$(git rev-parse --git-dir)" = "$(git rev-parse --git-common-dir)" ]; then
            git add "$REPO_ROOT/platform/raycast-scripts/" 2>/dev/null || true
        fi
    fi
fi

# === 3. Beads JSONL flush ===
if ! command -v bd >/dev/null 2>&1; then
    exit 0
fi

BEADS_DIR=""
if git rev-parse --git-dir >/dev/null 2>&1; then
    if [ "$(git rev-parse --git-dir)" != "$(git rev-parse --git-common-dir)" ]; then
        MAIN_REPO_ROOT="$(dirname "$(git rev-parse --git-common-dir)")"
        [ -d "$MAIN_REPO_ROOT/.beads" ] && BEADS_DIR="$MAIN_REPO_ROOT/.beads"
    else
        [ -d .beads ] && BEADS_DIR=".beads"
    fi
fi

[ -z "$BEADS_DIR" ] && exit 0

# Skip Dolt backend
if [ -f "$BEADS_DIR/metadata.json" ]; then
    if grep -q '"backend"[[:space:]]*:[[:space:]]*"dolt"' "$BEADS_DIR/metadata.json" 2>/dev/null; then
        exit 0
    fi
fi

# Flush pending changes
if ! bd sync --flush-only >/dev/null 2>&1; then
    echo "Error: Failed to flush bd changes to storage" >&2
    echo "Run 'bd sync --flush-only' manually to diagnose" >&2
    exit 1
fi

# Stage JSONL if modified (regular repo only, not worktrees)
if [ -f "$BEADS_DIR/issues.jsonl" ]; then
    if [ "$(git rev-parse --git-dir)" = "$(git rev-parse --git-common-dir)" ]; then
        git add "$BEADS_DIR/issues.jsonl" 2>/dev/null || true
    fi
fi

exit 0
