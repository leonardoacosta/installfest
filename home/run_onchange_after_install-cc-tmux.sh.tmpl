#!/usr/bin/env bash
# Install/wire cc-tmux — the first-party Claude Code + tmux plugin that tracks,
# cycles, and dispatches parallel Claude panes (apps/cc-tmux/). Installed
# manually (symlink + run-shell load), same as tmux-which-key, since this repo
# runs no TPM (see docs/audit/tmux.md N5).
#
# Three install actions:
#   (a) symlink apps/cc-tmux -> ~/.tmux/plugins/cc-tmux so tmux.conf's
#       `run-shell ~/.tmux/plugins/cc-tmux/cc-tmux.tmux` load line resolves.
#   (b) register the Claude Code plugin from the local clone so its state hooks
#       (waiting/idle/active) self-register WITHOUT editing cc's settings.json.
#   (d) re-run `tmux run-shell` on any LIVE tmux server so keybinding changes
#       in cc-tmux.tmux take effect immediately (if-8vqd) — editing/committing
#       the file does not retroactively rebind an already-running server's key
#       table, which has twice silently dropped bindings (MouseDown1Status)
#       with no error until Leo noticed tabs stopped working. This script only
#       re-runs when cc-tmux.tmux's own hash changes (see header), so (d) only
#       fires on an actual binding-relevant change, not every chezmoi apply.
#
# Re-runs whenever the plugin's install-relevant surface changes (the tmux
# entrypoint, the Claude hooks manifest, or the plugin manifest), so a fresh
# machine picks up the symlink + registration on first `chezmoi apply`. The
# `../apps/...` include escapes the chezmoi source root (home/) up to the repo
# root — verified with `chezmoi execute-template` that this resolves.
#
#   cc-tmux.tmux: {{ include "../apps/cc-tmux/cc-tmux.tmux" | sha256sum }}
#   hooks.json:   {{ include "../apps/cc-tmux/hooks/hooks.json" | sha256sum }}
#   plugin.json:  {{ include "../apps/cc-tmux/.claude-plugin/plugin.json" | sha256sum }}

set -euo pipefail

DOTFILES="{{ .chezmoi.workingTree }}"
. "$DOTFILES/scripts/utils.sh"

PLUGIN_SRC="$DOTFILES/apps/cc-tmux"
PLUGIN_LINK="$HOME/.tmux/plugins/cc-tmux"

# --- (a) symlink into ~/.tmux/plugins so the tmux run-shell load resolves ----
if [ ! -d "$PLUGIN_SRC" ]; then
  warning "cc-tmux: source $PLUGIN_SRC missing — skipping install"
  exit 0
fi

mkdir -p "$(dirname "$PLUGIN_LINK")"
if ln -sfn "$PLUGIN_SRC" "$PLUGIN_LINK"; then
  success "cc-tmux: linked $PLUGIN_LINK -> $PLUGIN_SRC"
else
  warning "cc-tmux: failed to symlink into ~/.tmux/plugins — tmux load will not resolve"
fi

# --- (b) register the Claude Code plugin from the local clone (idempotent) ----
# The plugin manifest self-registers its state hooks, so no settings.json edit
# is needed. Fail open: a registration failure must NOT abort `chezmoi apply`
# (the tmux side still loads via the symlink above).
if command -v claude >/dev/null 2>&1; then
  # Must check ENABLED, not just LISTED — a marketplace pointing at a stale path
  # (e.g. surviving a repo move like if -> personal/installfest) lists forever as
  # "cc-tmux@cc-tmux ... failed to load: cache-miss", and a plain presence grep
  # treats that as "already registered" and never re-points it (confirmed live —
  # this is exactly how the plugin silently never loaded).
  if claude plugin list 2>/dev/null | grep -A3 'cc-tmux@cc-tmux' | grep -q 'enabled'; then
    success "cc-tmux: Claude plugin already registered and enabled"
  elif [ -f "$PLUGIN_SRC/.claude-plugin/marketplace.json" ]; then
    # Re-point the marketplace at the current path (self-heals path drift), then
    # (re)install. Remove-before-add is idempotent when there's nothing to remove.
    claude plugin marketplace remove cc-tmux >/dev/null 2>&1 || true
    if claude plugin marketplace add "$PLUGIN_SRC" >/dev/null 2>&1 \
      && claude plugin install "cc-tmux@cc-tmux" >/dev/null 2>&1; then
      success "cc-tmux: Claude plugin registered from local clone"
    else
      warning "cc-tmux: 'claude plugin install' failed — state hooks not registered (tmux load unaffected). Register manually: claude plugin marketplace add $PLUGIN_SRC && claude plugin install cc-tmux@cc-tmux"
    fi
  else
    # No marketplace.json in the plugin dir yet: `claude plugin install` needs a
    # marketplace manifest to resolve a local plugin. Warn (don't fail) — this is
    # a plugin-packaging concern (apps/cc-tmux), not a deploy-wiring one.
    warning "cc-tmux: no .claude-plugin/marketplace.json in $PLUGIN_SRC — skipping Claude-hook registration. Add a marketplace manifest, then: claude plugin marketplace add $PLUGIN_SRC && claude plugin install cc-tmux@cc-tmux"
  fi
else
  warning "cc-tmux: 'claude' CLI not found — skipping Claude-hook registration (tmux load unaffected)"
fi

# --- (c) prerequisite checks (warn, never fail) ------------------------------
if command -v fzf >/dev/null 2>&1; then
  success "cc-tmux: fzf present — inbox/picker use the fzf popup"
else
  warning "cc-tmux: fzf not found — inbox/picker fall back to display-menu"
fi

if command -v python3 >/dev/null 2>&1; then
  success "cc-tmux: python3 present"
else
  warning "cc-tmux: python3 not found — cc-tmux CLI will not run until it is installed"
fi

# --- (d) re-register keybindings on any live tmux server (if-8vqd) ----------
# Bare `tmux.conf` edits/`run-shell` sourcing only take effect for NEW tmux
# servers — an already-running server's key table is untouched until
# `run-shell` is re-invoked against it. Fail open: never abort chezmoi apply
# over a re-registration failure (bindings just stay stale until manually run).
if command -v tmux >/dev/null 2>&1 && tmux list-sessions >/dev/null 2>&1; then
  if tmux run-shell "$PLUGIN_LINK/cc-tmux.tmux" >/dev/null 2>&1; then
    success "cc-tmux: re-registered keybindings on live tmux server"
  else
    warning "cc-tmux: 'tmux run-shell $PLUGIN_LINK/cc-tmux.tmux' failed — keybindings may be stale. Run manually: tmux run-shell $PLUGIN_LINK/cc-tmux.tmux"
  fi
else
  success "cc-tmux: no live tmux server — new servers will load current bindings"
fi
