#!/usr/bin/env zsh
# .zshenv - Entry point for zsh environment
# Sourced for ALL zsh instances (login, interactive, scripts)
# Managed by chezmoi: ~/.zshenv
#
# IMPORTANT: This file should ONLY set environment variables.
# Tool inits (starship, zoxide, fzf) belong in .zshrc for interactive shells.

# ============================================================
# Core
# ============================================================

# Dotfiles source directory
export DOTFILES="${DOTFILES:-$HOME/dev/if}"

# Locale
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# Editor (fallback chain: cursor → nvim → vim)
if command -v cursor &>/dev/null; then
  export EDITOR="cursor"
elif command -v nvim &>/dev/null; then
  export EDITOR="nvim"
else
  export EDITOR="vim"
fi
export VISUAL="$EDITOR"

# XDG Base Directories
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# ============================================================
# Platform: {{ .chezmoi.os }}
# ============================================================

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew (must come before user PATH — brew shellenv calls path_helper
# which rebuilds PATH and pushes unrecognized entries to the end)
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# ============================================================
# PATH (user binaries — AFTER brew shellenv to ensure priority)
# ============================================================

export PATH="$HOME/.claude/bin:$HOME/.local/bin:$PATH"

# Compilation flags for Homebrew native libs (Python builds, npm C extensions)
if [[ -n "$HOMEBREW_PREFIX" ]]; then
  export LDFLAGS="-L$HOMEBREW_PREFIX/opt/zlib/lib -L$HOMEBREW_PREFIX/opt/bzip2/lib"
  export CPPFLAGS="-I$HOMEBREW_PREFIX/opt/zlib/include -I$HOMEBREW_PREFIX/opt/bzip2/include"
fi

# pnpm (macOS path)
export PNPM_HOME="$HOME/Library/pnpm"

# Maestro (mobile testing)
[[ -d "$HOME/.maestro/bin" ]] && export PATH="$PATH:$HOME/.maestro/bin"

{{ else if eq .chezmoi.os "linux" -}}
# PATH (user binaries — no path_helper on Linux, safe to set early)
export PATH="$HOME/.claude/bin:$HOME/.local/bin:$PATH"

# pnpm (Linux path)
export PNPM_HOME="$HOME/.local/share/pnpm"

{{ end -}}
# ============================================================
# Shared dev toolchains
# ============================================================

# pnpm (add to PATH if installed)
[[ -d "$PNPM_HOME" ]] && [[ ":$PATH:" != *":$PNPM_HOME:"* ]] && export PATH="$PNPM_HOME:$PATH"

# Cargo/Rust
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# Go
[[ -d "/usr/local/go/bin" ]] && export PATH="$PATH:/usr/local/go/bin"
[[ -d "$HOME/go/bin" ]] && export PATH="$PATH:$HOME/go/bin"

# .NET (DOTNET_ROOT lets the host resolve SDKs/runtimes; tools dir hosts `dotnet tool install -g`)
{{ if eq .chezmoi.os "darwin" -}}
[[ -d "/usr/local/share/dotnet" ]] && export DOTNET_ROOT="/usr/local/share/dotnet"
[[ -z "$DOTNET_ROOT" && -n "$HOMEBREW_PREFIX" && -d "$HOMEBREW_PREFIX/opt/dotnet/libexec" ]] && export DOTNET_ROOT="$HOMEBREW_PREFIX/opt/dotnet/libexec"
{{ else if eq .chezmoi.os "linux" -}}
[[ -d "/usr/share/dotnet" ]] && export DOTNET_ROOT="/usr/share/dotnet"
{{ end -}}
[[ -d "$HOME/.dotnet/tools" ]] && export PATH="$PATH:$HOME/.dotnet/tools"

# ============================================================
# Build tool memory caps
# ============================================================
# Prevents runaway memory in ESLint (V8 heap) and Roslyn's VBCSCompiler
# (.NET GC heap). Caps are per-process — concurrent builders multiply this.
# Tune per-invocation with `NODE_OPTIONS=--max-old-space-size=N pnpm <cmd>`
# if you hit OOM on a legitimately large build (Next.js prod, large vitest).

# MSBuild: don't keep VBCSCompiler / dotnet build nodes alive between invocations.
# Trade-off: ~1-2s cold-start per build. Worth it to avoid 1.5GB lingering processes.
# Applies to Mac, homelab, Arch — universal.
export MSBUILDDISABLENODEREUSE=1

{{ if eq .chezmoi.os "darwin" -}}
# Mac (16GB): conservative cap that stops ESLint runaway dead.
# Override per-command if Next.js prod build needs more: NODE_OPTIONS=--max-old-space-size=8192 pnpm build
export NODE_OPTIONS="--max-old-space-size=4096"

{{ else if eq .machine "homelab" -}}
# Homelab (tight RAM, shared with Docker stack): hard caps prevent OOM that kills the box.
# Historical incident: ESLint + VBCSCompiler combined pushed past ~600MB headroom → swap thrash → SSH unreachable.
export NODE_OPTIONS="--max-old-space-size=1024"

# .NET runtime GC hard limit: 512MB. Clean OOM at the cap instead of unbounded growth.
# Value is hex bytes: 0x20000000 = 536870912 = 512MB. Bump to 0x40000000 for 1GB if needed.
export DOTNET_GCHeapHardLimit=0x20000000

# Aggressive GC mode (0-9, default 0). Higher = smaller working set, slightly more CPU.
export DOTNET_GCConserveMemory=9

{{ else if eq .chezmoi.os "linux" -}}
# Generic Linux fallback (Arch desktop, etc) — moderate caps.
export NODE_OPTIONS="--max-old-space-size=2048"

{{ end -}}
# ============================================================
# Local overrides (secrets, machine-specific tokens)
# ============================================================

# GitHub token — read from the OS keychain (stored by
# run_onchange_after_github-auth.sh). Keeps the PAT out of the repo/plaintext.
# Note: setting GH_TOKEN makes `gh` use this token directly (bypasses keyring
# account switching) — intended for a single-account setup.
{{ if eq .chezmoi.os "darwin" -}}
__gh_pat="$(security find-generic-password -w -s github-pat -a "$USER" 2>/dev/null)"
{{ else if eq .chezmoi.os "linux" -}}
__gh_pat="$(command -v secret-tool >/dev/null 2>&1 && secret-tool lookup service github-pat account "$USER" 2>/dev/null)"
{{ end -}}
if [[ -n "${__gh_pat:-}" ]]; then
  export GH_TOKEN="$__gh_pat"
  export GITHUB_TOKEN="$__gh_pat"
fi
unset __gh_pat

[[ -f ~/.zshenv.local ]] && source ~/.zshenv.local
