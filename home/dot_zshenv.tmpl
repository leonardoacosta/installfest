#!/usr/bin/env zsh
# .zshenv - Entry point for zsh environment
# Sourced for ALL zsh instances (login, interactive, scripts)
# Managed by chezmoi: ~/.zshenv
#
# IMPORTANT: This file should ONLY set environment variables.
# Tool inits (starship, zoxide, fzf) belong in .zshrc for interactive shells.

# ============================================================
# Core
# ============================================================

# Dotfiles source directory
export DOTFILES="${DOTFILES:-$HOME/dev/personal/installfest}"

# Locale
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# Editor (fallback chain: cursor → nvim → vim)
if command -v cursor &>/dev/null; then
  export EDITOR="cursor"
elif command -v nvim &>/dev/null; then
  export EDITOR="nvim"
else
  export EDITOR="vim"
fi
export VISUAL="$EDITOR"

{{ if eq .machine "homelab" -}}
# Browser opener — the homelab is headless, so route every browser-open (Claude
# Code OAuth, docs links, MCP auth) to the Mac over Tailscale. For loopback OAuth
# URLs the helper also reverse-tunnels the dynamic callback port back home, so the
# full login flow completes without interruption; if the Mac is down it prints a
# clickable URL. `mac-open` is scripts/mac-open.sh symlinked onto PATH by chezmoi
# (home/dot_local/bin/symlink_mac-open.tmpl). See if-ox3.
export BROWSER="$HOME/.local/bin/mac-open"
{{ end -}}

{{ if eq .machine "mac" -}}
# SSH agent socket — 1Password's SSH agent, Mac-only. Needs the live 1Password
# desktop app, which only runs on an interactive desktop; homelab is headless
# and CloudPC has no interactive desktop for its SSH service account, so
# neither gets this block. The on-disk ~/.ssh/id_ed25519 key (untouched by
# this file) still works as OpenSSH's automatic fallback identity if this
# socket isn't reachable (1Password app not running).
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{ else if eq .machine "homelab" -}}
# SSH agent socket — systemd socket-activated ssh-agent (no desktop needed,
# works headless). `leo-cc-homelab-20260721` auto-loads into it via the
# ssh-agent.service override (dot_config/systemd/user/ssh-agent.service.d/).
# Root cause this fixes: bd/Dolt's git+ssh remote had no agent to source a
# key from at all (`Could not open a connection to your authentication
# agent`), so every `bd dolt push`/`pull` failed publickey auth (if-kjbg).
export SSH_AUTH_SOCK="/run/user/1000/ssh-agent.socket"
{{ end -}}

# XDG Base Directories
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# ============================================================
# Platform: {{ .chezmoi.os }}
# ============================================================

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew (must come before user PATH — brew shellenv calls path_helper
# which rebuilds PATH and pushes unrecognized entries to the end)
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# ============================================================
# PATH (user binaries — AFTER brew shellenv to ensure priority)
# ============================================================

export PATH="$HOME/.claude/bin:$HOME/.local/bin:$PATH"

# Compilation flags for Homebrew native libs (Python builds, npm C extensions)
if [[ -n "$HOMEBREW_PREFIX" ]]; then
  export LDFLAGS="-L$HOMEBREW_PREFIX/opt/zlib/lib -L$HOMEBREW_PREFIX/opt/bzip2/lib"
  export CPPFLAGS="-I$HOMEBREW_PREFIX/opt/zlib/include -I$HOMEBREW_PREFIX/opt/bzip2/include"
fi

# pnpm (macOS path)
export PNPM_HOME="$HOME/Library/pnpm"

# Maestro (mobile testing)
[[ -d "$HOME/.maestro/bin" ]] && export PATH="$PATH:$HOME/.maestro/bin"

# Ghostty ssh wrapper under cmux — cmux embeds Ghostty's terminal engine and
# exports GHOSTTY_BIN_DIR/GHOSTTY_SHELL_FEATURES like real Ghostty, but its
# app bundle ships the binary as `cmux`, not `ghostty`. Ghostty's zsh
# integration installs its own `ssh` wrapper via a deferred precmd hook (which
# always wins over any user-defined `ssh` function, including ours in
# rc/shared.zsh — it (re)defines `ssh` on the first prompt, after .zshrc has
# already run). Its function body is `"$GHOSTTY_BIN_DIR/ghostty" +ssh ... --
# "$@"` — that exec is UNCONDITIONAL whenever the wrapper is installed at
# all; the ssh-env/ssh-terminfo feature flags only toggle --forward-env=false
# / --terminfo=false args, they do NOT gate the exec itself. The wrapper is
# installed whenever GHOSTTY_SHELL_FEATURES contains ANY "ssh-*" token, so
# stripping just ssh-terminfo (leaving ssh-env) still installs it and it
# still fails "no such file or directory" under cmux. Must strip every
# ssh-* token so the outer `*ssh-*` gate goes false and the wrapper is never
# installed — falls through to our own ssh() in rc/shared.zsh instead.
# GHOSTTY_SHELL_FEATURES is read dynamically at precmd time, so stripping it
# here (before precmd fires) takes effect. No-op under real Ghostty.app
# where the binary exists.
if [[ "$TERM_PROGRAM" == "ghostty" && -n "$GHOSTTY_BIN_DIR" && ! -x "$GHOSTTY_BIN_DIR/ghostty" ]]; then
  export GHOSTTY_SHELL_FEATURES="${${GHOSTTY_SHELL_FEATURES//ssh-terminfo/}//ssh-env/}"
fi

{{ else if eq .chezmoi.os "linux" -}}
# PATH (user binaries — no path_helper on Linux, safe to set early)
export PATH="$HOME/.claude/bin:$HOME/.local/bin:$PATH"

# pnpm (Linux path)
export PNPM_HOME="$HOME/.local/share/pnpm"

{{ end -}}
# ============================================================
# Shared dev toolchains
# ============================================================

# pnpm (add to PATH if installed)
[[ -d "$PNPM_HOME" ]] && [[ ":$PATH:" != *":$PNPM_HOME:"* ]] && export PATH="$PNPM_HOME:$PATH"

# Cargo/Rust
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# Go
[[ -d "/usr/local/go/bin" ]] && export PATH="$PATH:/usr/local/go/bin"
[[ -d "$HOME/go/bin" ]] && export PATH="$PATH:$HOME/go/bin"

# Bun global installs/links (bin dir location differs by install method: official
# installer defaults to ~/.bun/bin; XDG-respecting packages, e.g. Arch's pacman
# build, honor XDG_CACHE_HOME and write to <cache>/.bun/bin instead — check both).
[[ -d "$HOME/.bun/bin" ]] && export PATH="$PATH:$HOME/.bun/bin"
[[ -d "${XDG_CACHE_HOME:-$HOME/.cache}/.bun/bin" ]] && export PATH="$PATH:${XDG_CACHE_HOME:-$HOME/.cache}/.bun/bin"

# .NET (DOTNET_ROOT lets the host resolve SDKs/runtimes; tools dir hosts `dotnet tool install -g`)
{{ if eq .chezmoi.os "darwin" -}}
[[ -d "/usr/local/share/dotnet" ]] && export DOTNET_ROOT="/usr/local/share/dotnet"
[[ -z "$DOTNET_ROOT" && -n "$HOMEBREW_PREFIX" && -d "$HOMEBREW_PREFIX/opt/dotnet/libexec" ]] && export DOTNET_ROOT="$HOMEBREW_PREFIX/opt/dotnet/libexec"
{{ else if eq .chezmoi.os "linux" -}}
[[ -d "/usr/share/dotnet" ]] && export DOTNET_ROOT="/usr/share/dotnet"
{{ end -}}
[[ -d "$HOME/.dotnet/tools" ]] && export PATH="$PATH:$HOME/.dotnet/tools"

# ============================================================
# Build tool memory caps
# ============================================================
# Prevents runaway memory in ESLint (V8 heap) and Roslyn's VBCSCompiler
# (.NET GC heap). Caps are per-process — concurrent builders multiply this.
# Tune per-invocation with `NODE_OPTIONS=--max-old-space-size=N pnpm <cmd>`
# if you hit OOM on a legitimately large build (Next.js prod, large vitest).

# MSBuild: don't keep VBCSCompiler / dotnet build nodes alive between invocations.
# Trade-off: ~1-2s cold-start per build. Worth it to avoid 1.5GB lingering processes.
# Applies to Mac, homelab, Arch — universal.
export MSBUILDDISABLENODEREUSE=1

{{ if eq .chezmoi.os "darwin" -}}
# Mac (16GB): conservative cap that stops ESLint runaway dead.
# Override per-command if Next.js prod build needs more: NODE_OPTIONS=--max-old-space-size=8192 pnpm build
export NODE_OPTIONS="--max-old-space-size=4096"

{{ else if eq .machine "homelab" -}}
# Homelab (tight RAM, shared with Docker stack): hard caps prevent OOM that kills the box.
# Historical incident: ESLint + VBCSCompiler combined pushed past ~600MB headroom → swap thrash → SSH unreachable.
export NODE_OPTIONS="--max-old-space-size=1024"

# .NET runtime GC hard limit: 512MB. Clean OOM at the cap instead of unbounded growth.
# Value is hex bytes: 0x20000000 = 536870912 = 512MB. Bump to 0x40000000 for 1GB if needed.
export DOTNET_GCHeapHardLimit=0x20000000

# Aggressive GC mode (0-9, default 0). Higher = smaller working set, slightly more CPU.
export DOTNET_GCConserveMemory=9

{{ else if eq .chezmoi.os "linux" -}}
# Generic Linux fallback (Arch desktop, etc) — moderate caps.
export NODE_OPTIONS="--max-old-space-size=2048"

{{ end -}}
# ============================================================
# Secrets — three buckets, by ownership
# ============================================================
# priceless    Account-global secrets that belong to YOU (Priceless / personal)
#              and are reused across every repo. Stored in the OS keychain (seed
#              once), never in the repo. Note: exporting GH_TOKEN makes `gh` use
#              it directly (bypasses keyring account switching) — single-account.
#
# b-and-b      Brown & Brown employment credentials, account-global within work
#              (e.g. AZURE_DEVOPS_EXT_PAT — one all-orgs PAT for brownandbrowninc
#              + brownandbrown). Source of truth is 1Password (B&B/Employee
#              vault); the ado-auth bootstrap caches it in the keychain so the
#              shell export below stays silent (no per-shell biometric prompt).
#
# per-project  Secrets scoped to ONE repo: POSTGRES_URL, STRIPE_*, TURBO_TOKEN,
#              npm *publish* tokens, VERCEL_PROJECT_ID/ORG_ID, CLOUDFLARE_*,
#              TAILSCALE_AUTHKEY, SENTRY_AUTH_TOKEN, AZURE_* access tokens.
#              These live in each repo's .env / Terraform and MUST NOT be
#              exported here — a global export leaks one project's secret into
#              every shell. (AZURE_* are also short-lived; the mx-broker helper
#              mints them on demand. AZURE_CONFIG_DIR in the `az` wrapper is a
#              config pointer, not a secret.)

# --- priceless: keychain-backed secrets -------------------------------------
# Read one secret from the platform keychain by service name (echoes or empty).
{{ if eq .chezmoi.os "darwin" -}}
__kc_read() { security find-generic-password -w -s "$1" -a "$USER" 2>/dev/null; }
{{ else if eq .chezmoi.os "linux" -}}
__kc_read() { command -v secret-tool >/dev/null 2>&1 && secret-tool lookup service "$1" account "$USER" 2>/dev/null; }
{{ end -}}
# 'service-name:VAR[,VAR...]' — items not present in the keychain are skipped.
# Seed one with: security add-generic-password -U -s <service> -a "$USER" -w '<value>'
for __row in \
  'github-pat:GH_TOKEN,GITHUB_TOKEN' \
  'ai-gateway-key:AI_GATEWAY_API_KEY' \
  'openai-key:OPENAI_API_KEY'; do
  __val="$(__kc_read "${__row%%:*}")"
  [[ -n "$__val" ]] || continue
  __vars="${__row#*:}"
  for __var in ${(s:,:)__vars}; do export "$__var=$__val"; done
done
unset __row __val __vars __var

# --- b-and-b: keychain-backed work secrets (seeded from 1Password) ----------
# Cached from the B&B/Employee 1Password vault by run_onchange_after_ado-auth.sh.
for __row in \
  'ado-pat:AZURE_DEVOPS_EXT_PAT'; do
  __val="$(__kc_read "${__row%%:*}")"
  [[ -n "$__val" ]] || continue
  __vars="${__row#*:}"
  for __var in ${(s:,:)__vars}; do export "$__var=$__val"; done
done
unset __row __val __vars __var
unfunction __kc_read 2>/dev/null

# --- priceless derives: no secret of their own, computed from the above -----
if [[ -n "${GH_TOKEN:-}" ]]; then
  # Lift Homebrew's 60 req/hr unauthenticated GitHub API rate cap.
  export HOMEBREW_GITHUB_API_TOKEN="$GH_TOKEN"
  # GitHub Packages (npm.pkg.github.com, e.g. @nessprim) authenticates with the
  # gh PAT itself — needs the 'read:packages' scope (added at gh auth login).
  # ~/.npmrc references ${NPM_TOKEN} so npm/pnpm resolve it at install time.
  export NPM_TOKEN="$GH_TOKEN"
fi

[[ -f ~/.zshenv.local ]] && source ~/.zshenv.local
