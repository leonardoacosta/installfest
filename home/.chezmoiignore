# Files in home/ that should NOT be deployed to ~
# (dirs outside home/ are invisible to chezmoi — no need to list them)
projects.toml

# SECRET: real Upstash MCP credentials. Only env.example (placeholders) is managed.
# The operator copies env.example -> env on each machine and supplies the real key.
.config/upstash-mcp/env

# Platform-specific ignores
{{ if ne .chezmoi.os "darwin" }}
# Skip macOS-only files on Linux (patterns match TARGET paths, not source)
.config/ghostty
.config/karabiner
.config/1Password
Library
{{ end }}

{{ if ne .chezmoi.os "linux" }}
# Skip Linux-only files on macOS (patterns match TARGET paths, not source)
.config/hypr
.config/systemd
{{ end }}

# NOTE: .config/{Code,Cursor} deploy on BOTH macOS and Linux for path symmetry.
# On macOS, the apps actually read from ~/Library/Application Support/{Code,Cursor}/User/,
# but mirroring at ~/.config/ makes scripts and CLI access identical across OSes.
# (Library/ paths still skip on Linux — see top block.)
