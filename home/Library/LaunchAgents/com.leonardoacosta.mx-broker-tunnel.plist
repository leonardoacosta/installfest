<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.leonardoacosta.mx-broker-tunnel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/ssh</string>
        <string>-nNT</string>
        <string>-o</string>
        <string>ExitOnForwardFailure=yes</string>
        <string>-o</string>
        <string>StreamLocalBindUnlink=yes</string>
        <string>-o</string>
        <string>ServerAliveInterval=30</string>
        <string>-o</string>
        <string>ServerAliveCountMax=3</string>
        <string>-L</string>
        <string>/Users/leonardoacosta/.mx/broker/broker.sock:/home/nyaptor/.mx/broker/broker.sock</string>
        <string>homelab</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <!-- Unconditional restart-on-exit (was NetworkState-only, which never
         retries after a DNS-resolution race at boot -- confirmed live
         2026-07-22: the tunnel died with "Could not resolve hostname
         homelab.tail296462.ts.net" (Tailscale MagicDNS not ready yet at
         RunAtLoad time) and sat dead until manually kickstarted, since the
         network state genuinely never changed afterward. ThrottleInterval
         below prevents a tight crash loop while DNS/network settles. -->
    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/leonardoacosta</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/leonardoacosta/.local/logs/mx-broker-tunnel.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/leonardoacosta/.local/logs/mx-broker-tunnel.err.log</string>
</dict>
</plist>
