#!/usr/bin/env bash
# Bootstrap user-scope schedulers and daemons on the current OS.
# Re-runs whenever any referenced file changes — embedded sha256sums force
# chezmoi to re-render the template when source content shifts.
#
#   weekly-cleanup script:    {{ include "dot_local/bin/executable_weekly-cleanup" | sha256sum }}
#   nexus-listener script:    {{ include "dot_local/share/nexus-listener.ts" | sha256sum }}
#   daily-brief entry script: {{ include "../apps/daily-brief/src/index.tsx" | sha256sum }}
{{- if eq .chezmoi.os "darwin" }}
#   weekly-cleanup plist:     {{ include "Library/LaunchAgents/com.leonardoacosta.weekly-cleanup.plist" | sha256sum }}
#   nexus-listener plist:     {{ include "Library/LaunchAgents/com.leonardoacosta.nexus-listener.plist" | sha256sum }}
#   cmux-bridge plist:        {{ include "Library/LaunchAgents/com.leonardoacosta.cmux-bridge.plist" | sha256sum }}
#   cmux-bridge main.rs:      {{ include "../ssh-mesh/scripts/remote/cmux-bridge/src/main.rs" | sha256sum }}
#   cmux-bridge Cargo.toml:   {{ include "../ssh-mesh/scripts/remote/cmux-bridge/Cargo.toml" | sha256sum }}
#   daily-brief plist:        {{ include "Library/LaunchAgents/com.leonardoacosta.daily-brief.plist" | sha256sum }}
{{- else if eq .chezmoi.os "linux" }}
#   weekly-cleanup service:   {{ include "dot_config/systemd/user/weekly-cleanup.service" | sha256sum }}
#   weekly-cleanup timer:     {{ include "dot_config/systemd/user/weekly-cleanup.timer" | sha256sum }}
#   nexus-listener service:   {{ include "dot_config/systemd/user/nexus-listener.service" | sha256sum }}
#   cmux-relay-cleanup svc:   {{ include "dot_config/systemd/user/cmux-relay-cleanup.service" | sha256sum }}
#   az-reauth-nudge script:   {{ include "../scripts/az-reauth-nudge.sh" | sha256sum }}
#   az-reauth-nudge service:  {{ include "dot_config/systemd/user/az-reauth-nudge.service" | sha256sum }}
#   az-reauth-nudge timer:    {{ include "dot_config/systemd/user/az-reauth-nudge.timer" | sha256sum }}
#   mesh-heartbeat script:    {{ include "../scripts/mesh-heartbeat.sh" | sha256sum }}
#   mesh-heartbeat service:   {{ include "dot_config/systemd/user/mesh-heartbeat.service" | sha256sum }}
#   mesh-heartbeat timer:     {{ include "dot_config/systemd/user/mesh-heartbeat.timer" | sha256sum }}
#   daily-brief service:      {{ include "dot_config/systemd/user/daily-brief.service" | sha256sum }}
#   daily-brief timer:        {{ include "dot_config/systemd/user/daily-brief.timer" | sha256sum }}
#   ssh-agent-keys drop-in:   {{ include "dot_config/systemd/user/ssh-agent.service.d/homelab-keys.conf" | sha256sum }}
{{- end }}

set -euo pipefail

DOTFILES="{{ .chezmoi.workingTree }}"
mkdir -p "$HOME/.local/state"

case "$(uname -s)" in
  Darwin)
    UID_=$(id -u)

    # ── Disable obsolete bash listener ─────────────────────────────────
    # The legacy `com.nexus.notifier` is the bash SSE listener that has
    # the FIFO-write blocking bug (see docs/notifier-investigation.html).
    # We unconditionally bootout on every chezmoi apply because the
    # upstream nexus install reloads it on login. Idempotent — silent
    # if not loaded.
    launchctl bootout "gui/${UID_}/com.nexus.notifier" 2>/dev/null || true

    bootstrap_plist() {
      local label="$1" plist
      plist="$HOME/Library/LaunchAgents/${label}.plist"
      if [[ ! -f "$plist" ]]; then
        echo "scheduler: ${label} plist not yet deployed; skipping"
        return 0
      fi
      # bootout drops the previous instance before re-bootstrapping with
      # new content. kickstart -k alone doesn't pick up plist edits
      # because launchd caches the schedule.
      launchctl bootout "gui/${UID_}/${label}" 2>/dev/null || true
      # bootout returns before the old process fully releases its resources
      # (socket/port teardown is async) — an immediate bootstrap can race it
      # and fail with "Bootstrap failed: 5: Input/output error" (reproduced
      # live 2026-07-14: 0s gap fails, 1s gap succeeds). Retry with backoff
      # instead of a single unconditional sleep, so the common no-race case
      # stays instant.
      local tries=0
      until launchctl bootstrap "gui/${UID_}" "$plist" 2>/dev/null; do
        tries=$((tries + 1))
        if (( tries >= 5 )); then
          echo "scheduler: ${label} bootstrap failed after ${tries} attempts" >&2
          return 1
        fi
        sleep 1
      done
      echo "scheduler: launchd loaded gui/${UID_}/${label}"
    }
    bootstrap_plist com.leonardoacosta.weekly-cleanup
    bootstrap_plist com.leonardoacosta.nexus-listener
    bootstrap_plist com.leonardoacosta.daily-brief

    # ── cmux-bridge: build-from-source (if-j8g) ────────────────────────
    # No prebuilt binary is committed (arch-specific, non-reproducible) —
    # cargo build is naturally incremental, so this is a no-op fast-path
    # once built. Guarded by command -v so a machine without Rust just
    # skips it (remote-CC-hook callbacks degrade to unavailable, not a
    # broken apply).
    if command -v cargo >/dev/null 2>&1; then
      mkdir -p "$HOME/.local/logs"
      if cargo build --release --manifest-path \
          "$DOTFILES/ssh-mesh/scripts/remote/cmux-bridge/Cargo.toml" \
          >"$HOME/.local/logs/cmux-bridge-build.log" 2>&1; then
        bootstrap_plist com.leonardoacosta.cmux-bridge
      else
        echo "scheduler: cmux-bridge build failed — see ~/.local/logs/cmux-bridge-build.log"
      fi
    else
      echo "scheduler: cargo not available; skipping cmux-bridge (install Rust first)"
    fi
    ;;

  Linux)
    if ! command -v systemctl >/dev/null 2>&1; then
      echo "scheduler: systemctl not available; skipping"
      exit 0
    fi
    HAVE_BUN=1
    if ! command -v bun >/dev/null 2>&1; then
      HAVE_BUN=0
      echo "scheduler: bun not available; skipping nexus-listener (install bun first)"
    fi
    systemctl --user daemon-reload
    # Socket-activated ssh-agent (headless-safe — no desktop keyring needed).
    # The ssh-agent.service.d drop-in auto-loads the GitHub key on each start;
    # without this, bd's git+ssh Dolt remote has no agent to auth with at all.
    systemctl --user enable --now ssh-agent.socket
    echo "scheduler: enabled ssh-agent.socket"
    # Stop/disable the legacy bash notifier service if it's installed.
    systemctl --user stop nexus-notifier.service 2>/dev/null || true
    systemctl --user disable nexus-notifier.service 2>/dev/null || true
    # Enable our managed units. nexus-listener requires bun at runtime — skip
    # it entirely (not just warn) when bun is absent, or `enable --now` fails
    # and aborts the whole chezmoi apply under set -e (if-vit.1).
    for unit in weekly-cleanup.timer nexus-listener.service az-reauth-nudge.timer mesh-heartbeat.timer; do
      if [ "$unit" = "nexus-listener.service" ] && [ "$HAVE_BUN" -eq 0 ]; then
        continue
      fi
      systemctl --user enable --now "$unit"
      echo "scheduler: enabled ${unit}"
    done
    # Boot-only oneshot: enable for boot but NOT --now — running it mid-deploy
    # would wipe relay state for any live cmux ssh session. It fires at the
    # next boot (clearing reboot-orphaned slots); start manually if needed.
    systemctl --user enable cmux-relay-cleanup.service
    echo "scheduler: enabled cmux-relay-cleanup.service (runs at boot)"

    # ── daily-brief: bun-dependent, guarded (if-vit.1 bun-less-brick class) ──
    # daily-brief.service's ExecStart runs `bun run ...` -- on a bun-less box
    # enabling it anyway would either fail the enable/start outright or leave
    # a unit that only ever crash-loops. Skip with a warning instead; never
    # `exit` non-zero here, so a missing bun never aborts the rest of this
    # run_onchange script (or chezmoi apply as a whole).
    if command -v bun >/dev/null 2>&1; then
      systemctl --user enable --now daily-brief.timer
      echo "scheduler: enabled daily-brief.timer"
    else
      echo "scheduler: bun not available; skipping daily-brief.timer (install bun first)"
    fi

    systemctl --user list-timers weekly-cleanup.timer az-reauth-nudge.timer mesh-heartbeat.timer daily-brief.timer --no-pager 2>/dev/null || true
    systemctl --user status nexus-listener.service --no-pager 2>/dev/null | head -5 || true
    ;;

  *)
    echo "scheduler: unsupported OS $(uname -s); skipping"
    ;;
esac
