#!/usr/bin/env bash
# run_once_install-packages.sh - chezmoi run_once package installer
# Runs once per machine (chezmoi tracks by content hash)

set -uo pipefail
# Note: -e intentionally omitted — brew bundle may return non-zero
# for already-installed casks or optional failures that shouldn't abort

DOTFILES="{{ .chezmoi.workingTree }}"
export DOTFILES
export CHEZMOI=1

# Source utilities
. "$DOTFILES/scripts/utils.sh"

info "========================================"
info "  Dotfiles Package Installer (chezmoi)"
info "  Platform: $(uname -s) ($(uname -m))"
info "  Source:   $DOTFILES"
info "========================================"
echo

{{ if eq .chezmoi.os "darwin" -}}
info "Detected macOS"

# Source Mac prerequisites
. "$DOTFILES/scripts/prerequisites.sh"
. "$DOTFILES/scripts/brew-install.sh"
. "$DOTFILES/scripts/osx-defaults.sh"
. "$DOTFILES/scripts/terminal.sh"

# Core packages (non-interactive — chezmoi run_once must complete without prompts)
install_xcode
install_rosetta   # Apple Silicon: required before ProxyBridge (x86-only pkg) installs
install_homebrew
run_brew_bundle || warning "brew bundle had errors (some casks may need manual install)"

# Global CLI tools installed via package manager (idempotent: pnpm add -g no-ops if installed)
# live-server: Live Server replacement for static-file dev with auto-reload
if command -v pnpm &>/dev/null; then
    pnpm add -g live-server >/dev/null 2>&1 && success "live-server installed" || warning "live-server install failed (run: pnpm add -g live-server)"
fi

# Bicep CLI — not a Homebrew formula; install via Azure CLI (binary downloader).
# Lands at ~/.azure/bin/bicep; symlink into ~/.local/bin so Zed's langserver
# finds it on PATH without needing to extend $PATH globally.
if command -v az &>/dev/null; then
    if [[ ! -x "$HOME/.azure/bin/bicep" ]]; then
        az bicep install >/dev/null 2>&1 && success "Bicep CLI installed via az" || warning "az bicep install failed"
    fi
    if [[ -x "$HOME/.azure/bin/bicep" ]]; then
        mkdir -p "$HOME/.local/bin"
        ln -sf "$HOME/.azure/bin/bicep" "$HOME/.local/bin/bicep"
    fi
fi

# macOS system defaults
apply_osx_system_defaults || warning "Some macOS defaults failed (non-fatal)"

# Terminal setup
terminal || true

# Install ProxyBridge (per-app SOCKS5 proxy for Microsoft CAE bypass)
if [[ ! -d "/Applications/ProxyBridge.app" ]]; then
    PROXYBRIDGE_VERSION="3.2.0"
    PROXYBRIDGE_PKG="/tmp/ProxyBridge.pkg"
    info "Installing ProxyBridge v${PROXYBRIDGE_VERSION}..."
    curl -Lo "$PROXYBRIDGE_PKG" "https://github.com/InterceptSuite/ProxyBridge/releases/download/v${PROXYBRIDGE_VERSION}/ProxyBridge-v${PROXYBRIDGE_VERSION}-Universal-Installer.pkg"
    sudo installer -pkg "$PROXYBRIDGE_PKG" -target / && success "ProxyBridge installed" || warning "ProxyBridge install failed (may need manual install)"
    rm -f "$PROXYBRIDGE_PKG"
    info "NOTE: Approve ProxyBridge Network Extension on first launch:"
    info "  System Settings → General → Login Items & Extensions → Network Extensions"
    info "Import proxy rules from: $DOTFILES/scripts/proxybridge-rules.json"
else
    success "ProxyBridge already installed"
fi

# Import proxy rules into ProxyBridge. Only safe while ProxyBridge is NOT
# running (it rewrites its plist on quit). On a fresh boot the app hasn't
# launched yet, so this lands the rules before first launch. If ProxyBridge is
# already running, the importer no-ops with guidance — run it manually after
# quitting: bash "$DOTFILES/scripts/proxybridge-import-rules.sh"
if [[ -f "$DOTFILES/scripts/proxybridge-import-rules.sh" ]]; then
    if ! pgrep -f "ProxyBridge" >/dev/null 2>&1; then
        bash "$DOTFILES/scripts/proxybridge-import-rules.sh" \
            && success "ProxyBridge rules imported" \
            || warning "ProxyBridge rule import failed (import manually)"
    else
        info "ProxyBridge running — skipping rule import."
        info "  To import: quit ProxyBridge, run scripts/proxybridge-import-rules.sh, relaunch"
    fi
fi

# Ensure mx-broker socket + log dirs exist before the tunnel LaunchAgent binds.
mkdir -p "$HOME/.mx/broker" && chmod 700 "$HOME/.mx/broker"
mkdir -p "$HOME/.local/logs"

# Load LaunchAgents
for plist_name in com.leonardoacosta.cloudpc-tunnel com.leonardoacosta.mx-broker-tunnel com.leonardoacosta.validate-proxy; do
    plist="$HOME/Library/LaunchAgents/${plist_name}.plist"
    if [[ -f "$plist" ]] && ! launchctl list | grep -q "$plist_name"; then
        launchctl bootstrap "gui/$(id -u)" "$plist" 2>/dev/null || true
        success "Loaded $plist_name LaunchAgent"
    fi
done

# Load mic-priority LaunchAgent
if [[ -f "$HOME/Library/LaunchAgents/com.leonardoacosta.mic-priority.plist" ]]; then
    chmod +x "$DOTFILES/scripts/mic-priority.sh" 2>/dev/null || true
    if ! launchctl list | grep -q "com.leonardoacosta.mic-priority"; then
        launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/com.leonardoacosta.mic-priority.plist" 2>/dev/null || true
        success "Loaded mic-priority LaunchAgent"
    fi
fi

{{ else if eq .chezmoi.os "linux" -}}
info "Detected Linux"

# Check if Arch Linux
if [[ -f /etc/arch-release ]]; then
    . "$DOTFILES/scripts/install-arch.sh"
else
    warning "Non-Arch Linux detected. Package install skipped."
    warning "Install zsh plugins manually for your distribution."
fi

# Enable systemd user services (file-server + cloudpc tunnel)
if command -v systemctl &>/dev/null; then
    for svc in file-server cloudpc-tunnel; do
        if [[ -f "$HOME/.config/systemd/user/${svc}.service" ]]; then
            systemctl --user enable "$svc" 2>/dev/null && success "Enabled $svc service" || true
        fi
    done
    systemctl --user daemon-reload 2>/dev/null || true
fi

{{ end -}}

# === SSH mesh setup (all platforms) ===
# SSH config is managed by chezmoi (private_dot_ssh/config.tmpl)
# Keys must be placed manually once — they are gitignored for security
if [[ -f "$HOME/.ssh/id_ed25519.pub" ]]; then
    # Set up authorized_keys for inbound SSH connections
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    cp "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/authorized_keys"
    chmod 600 "$HOME/.ssh/authorized_keys"
    success "SSH authorized_keys configured for inbound connections"

    # Add key to SSH agent
    ssh-add "$HOME/.ssh/id_ed25519" 2>/dev/null || true
else
    warning "SSH key not found (~/.ssh/id_ed25519)"
    warning "Copy the mesh key pair to this machine for SSH mesh connectivity"
    warning "  scp <source>:~/dev/if/ssh-mesh/keys/id_ed25519* ~/.ssh/"
fi

# === Final messages ===
echo
success "========================================"
success "  Package Installation Complete!"
success "========================================"
echo
info "Next steps:"
info "  1. Restart your terminal or run: source ~/.zshrc"
info "  2. Verify starship prompt is working"
info "  3. Run 'z --help' to learn zoxide"
info "  4. Run 'atuin login' to sync history (optional)"
if [[ ! -f "$HOME/.ssh/id_ed25519" ]]; then
    info "  5. Copy SSH mesh keys: scp <source>:~/dev/if/ssh-mesh/keys/id_ed25519* ~/.ssh/"
fi
echo

# === Phase 1 -> Phase 2 handoff (both platforms) ===
# This run_once installer IS Phase 1 of the documented 2-phase cold-start.
# Point the operator at the interactive Phase 2 (Apple-ID/2FA gates + project
# clones) — see README.md § Quick Start. Just an echo: run_once stays
# non-interactive and completes cleanly.
success "Phase 1 complete. Next: run ~/dev/if/platform/bootstrap.sh for interactive setup (Xcode signing, project clones)."
echo
