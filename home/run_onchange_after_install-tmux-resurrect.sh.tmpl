#!/usr/bin/env bash
# Install/update tmux-plugins/tmux-resurrect — session-persistence plugin that
# saves/restores tmux window & pane layout + working directories across a server
# crash, `tmux kill-server`, or reboot. Installed manually since this repo runs
# no TPM (see docs/audit/tmux.md N5 — deliberate: single run-shell line is
# cleaner than TPM for one plugin).
#
# Re-runs whenever tmux.conf changes (the file that wires this plugin in) so
# a fresh machine picks up the clone automatically on first `chezmoi apply`.
#
#   tmux.conf: {{ include "dot_config/tmux/tmux.conf.tmpl" | sha256sum }}

set -euo pipefail

DOTFILES="{{ .chezmoi.workingTree }}"
. "$DOTFILES/scripts/utils.sh"

PLUGIN_DIR="$HOME/.tmux/plugins/tmux-resurrect"
REPO="https://github.com/tmux-plugins/tmux-resurrect"

if ! command -v git >/dev/null 2>&1; then
  warning "tmux-resurrect: git not available; skipping install"
  exit 0
fi

if [ -d "$PLUGIN_DIR/.git" ]; then
  info "tmux-resurrect: updating existing clone"
  git -C "$PLUGIN_DIR" pull --ff-only --recurse-submodules || \
    warning "tmux-resurrect: pull failed — leaving existing clone as-is"
else
  info "tmux-resurrect: cloning to $PLUGIN_DIR"
  mkdir -p "$(dirname "$PLUGIN_DIR")"
  if git clone --recursive "$REPO" "$PLUGIN_DIR"; then
    success "tmux-resurrect: cloned"
  else
    warning "tmux-resurrect: clone failed — plugin will not load until this succeeds"
  fi
fi
