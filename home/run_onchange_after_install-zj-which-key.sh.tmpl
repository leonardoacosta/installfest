#!/usr/bin/env bash
# Install/update johnae/zj-which-key — mode-aware keybinding popup + fuzzy
# all-modes browser for zellij (which-key style), the zellij counterpart to
# tmux-which-key (run_onchange_after_install-tmux-which-key.sh.tmpl).
# Downloads the prebuilt release .wasm — no Rust/wasm32-wasip1 toolchain needed.
#
# Re-runs whenever zellij's config.kdl changes (the file that wires this
# plugin in) so a fresh machine picks up the download automatically.
#
#   config.kdl: {{ include "dot_config/zellij/config.kdl.tmpl" | sha256sum }}

set -euo pipefail

DOTFILES="{{ .chezmoi.workingTree }}"
. "$DOTFILES/scripts/utils.sh"

PLUGIN_DIR="$HOME/.local/share/zellij/plugins"
PLUGIN_PATH="$PLUGIN_DIR/zj_which_key.wasm"
REPO="johnae/zj-which-key"

if ! command -v curl >/dev/null 2>&1; then
  warning "zj-which-key: curl not available; skipping install"
  exit 0
fi

mkdir -p "$PLUGIN_DIR"

DOWNLOAD_URL=$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" \
  | grep -o '"browser_download_url": *"[^"]*zj_which_key\.wasm"' \
  | head -1 | sed 's/.*"\(https[^"]*\)"/\1/')

if [ -z "$DOWNLOAD_URL" ]; then
  warning "zj-which-key: could not resolve latest release asset URL — leaving existing install as-is"
  exit 0
fi

info "zj-which-key: downloading $DOWNLOAD_URL"
if curl -fsSL "$DOWNLOAD_URL" -o "$PLUGIN_PATH.tmp"; then
  mv "$PLUGIN_PATH.tmp" "$PLUGIN_PATH"
  success "zj-which-key: installed to $PLUGIN_PATH"
else
  rm -f "$PLUGIN_PATH.tmp"
  warning "zj-which-key: download failed — plugin will not load until this succeeds"
  exit 0
fi

# Pre-grant the plugin's permissions. Zellij normally asks you to press `y` in
# the plugin's own pane to approve permissions, but neither of this plugin's
# panes can receive that keystroke (the popup is non-selectable by design, and
# a background-loaded plugin has no pane at all — zellij-org/zellij#4982). The
# grant has to exist in zellij's permissions cache before first run or the
# plugin silently never activates.
{{ if eq .chezmoi.os "darwin" -}}
PERM_DIR="$HOME/Library/Caches/org.Zellij-Contributors.Zellij"
{{ else -}}
PERM_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zellij"
{{ end -}}
PERM_FILE="$PERM_DIR/permissions.kdl"
mkdir -p "$PERM_DIR"
touch "$PERM_FILE"

if ! grep -qF "\"$PLUGIN_PATH\"" "$PERM_FILE" 2>/dev/null; then
  info "zj-which-key: pre-granting plugin permissions in $PERM_FILE"
  cat >> "$PERM_FILE" <<EOF
"$PLUGIN_PATH" {
    ReadApplicationState
    ChangeApplicationState
    MessageAndLaunchOtherPlugins
}
EOF
  success "zj-which-key: permissions granted"
else
  info "zj-which-key: permissions already granted"
fi
