{{- $hostname := .chezmoi.hostname -}}
{{- $theme := "vercel" -}}
{{- $machine := "unknown" -}}
{{- $sshUser := .chezmoi.username -}}

{{- if or (eq $hostname "leonardoacostas-MacBook-Pro") (eq $hostname "Leonardos-MacBook-Pro") -}}
{{-   $machine = "mac" -}}
{{-   $sshUser = "leonardoacosta" -}}
{{- else if eq $hostname "homelab" -}}
{{-   $machine = "homelab" -}}
{{-   $sshUser = "nyaptor" -}}
{{- else if and (eq .chezmoi.os "linux") (stat "/etc/arch-release") -}}
{{/* Transient hostnames (e.g. fresh install or post-rollback "archlinux")
     still resolve to the homelab profile so hardening scripts fire. */}}
{{-   $machine = "homelab" -}}
{{-   $sshUser = .chezmoi.username -}}
{{- end -}}

sourceDir = "{{ .chezmoi.homeDir }}/dev/if"

[data]
  theme = "{{ $theme }}"
  machine = "{{ $machine }}"
  ssh_user = "{{ $sshUser }}"
