#!/usr/bin/env bash
# run_onchange_after_ado-auth.sh — wire GitKraken's Azure DevOps provider from a
# 1Password-stored PAT, and cache the PAT in the OS keychain so ~/.zshenv exports
# AZURE_DEVOPS_EXT_PAT (auto-auths GitKraken + `az devops` + scripts/ado).
#
# B&B (employment) credential — the source of truth lives in 1Password, NOT this
# repo. This script fetches it via `op read` and caches it locally; ~/.zshenv
# reads the keychain copy silently (no per-shell biometric prompt).
#
# PREREQUISITES (one-time):
#   1. op (1Password CLI, Brewfile cask) + app integration:
#      1Password 8 > Settings > Developer > "Integrate with 1Password CLI".
#   2. An Azure DevOps PAT scoped to "All accessible organizations" (so it covers
#      dev.azure.com/brownandbrowninc AND dev.azure.com/brownandbrown), stored in
#      1Password at $OP_ADO_ITEM (default below; override by exporting it).
#
# TTY-guarded: non-interactive / mesh applies skip cleanly (op needs an unlock).

set -uo pipefail

info()    { printf '  ->  %s\n' "$*"; }
success() { printf '  OK  %s\n' "$*"; }
warn()    { printf 'WARN  %s\n' "$*"; }

if [[ ! -t 0 || -n "${CI:-}" ]]; then
	echo "ado-auth: non-interactive shell — skipping (op needs an interactive unlock)."
	exit 0
fi

# 1Password reference for the ADO PAT. Override by exporting OP_ADO_ITEM before
# `chezmoi apply`. Form: op://<vault>/<item>/<field>.
: "${OP_ADO_ITEM:=op://Private/ado-pat/credential}"

command -v op >/dev/null 2>&1 || {
	warn "op (1Password CLI) not installed — run 'brew bundle' first. Skipping ADO wiring."
	exit 0
}
if ! op whoami >/dev/null 2>&1; then
	info "Signing in to the 1Password CLI (approve in the app / Touch ID)..."
	op signin >/dev/null 2>&1 || {
		warn "op signin failed — enable Settings > Developer > Integrate with 1Password CLI, then re-run."
		exit 0
	}
fi

PAT="$(op read "$OP_ADO_ITEM" 2>/dev/null || true)"
if [[ -z "$PAT" ]]; then
	warn "Could not read $OP_ADO_ITEM from 1Password."
	warn "Create an ADO PAT (all-orgs scope), store it there, or set OP_ADO_ITEM to your ref."
	exit 0
fi

# Cache in the OS keychain so ~/.zshenv exports AZURE_DEVOPS_EXT_PAT silently.
{{ if eq .chezmoi.os "darwin" -}}
security add-generic-password -U -a "$USER" -s ado-pat -w "$PAT" >/dev/null 2>&1 \
	&& success "ADO PAT cached in keychain (service: ado-pat)."
{{ else if eq .chezmoi.os "linux" -}}
if command -v secret-tool >/dev/null 2>&1; then
	printf '%s' "$PAT" | secret-tool store --label="ado-pat" service ado-pat account "$USER" \
		&& success "ADO PAT cached in libsecret (service: ado-pat)."
else
	warn "secret-tool not found — AZURE_DEVOPS_EXT_PAT env export will be unavailable."
fi
{{ end -}}

# GitKraken provider attach. The CLI currently rejects ADO PATs ("azure pats not
# yet supported", gk 3.1.x) and the GUI token store (~/.gitkraken/secFile) is
# encrypted — so this can't be fully scripted today. We try the CLI anyway (so it
# auto-completes the day GitKraken ships ADO-PAT support), and on failure pre-stage
# the one manual GUI step: copy the PAT to the clipboard + print the exact fields.
ADO_HOST_DOMAIN="${ADO_HOST_DOMAIN:-dev.azure.com/brownandbrowninc}"
if command -v gk >/dev/null 2>&1 && gk whoami >/dev/null 2>&1 \
   && gk provider add azure -t "$PAT" >/dev/null 2>&1; then
	success "gk: Azure DevOps provider attached via CLI."
else
	info "gk CLI can't attach ADO yet — pre-staging the GUI step."
	{{ if eq .chezmoi.os "darwin" -}}
	printf '%s' "$PAT" | pbcopy && info "ADO PAT copied to clipboard."
	{{ end -}}
	cat <<-EOF
	  Connect GitKraken's Azure DevOps integration (one-time, in the app):
	    1. The "Connect the Azure DevOps integration" prompt -> the provider form.
	    2. Host Domain:           $ADO_HOST_DOMAIN
	    3. Personal Access Token: paste (already on your clipboard).
	    4. Connect. (PAT needs Code: Read & Write for git push/pull.)
	EOF
fi

echo "ado-auth: done. Open a new shell to pick up AZURE_DEVOPS_EXT_PAT."
