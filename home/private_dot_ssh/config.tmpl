{{/* Colima (macOS container runtime) re-writes an Include line at the top of
     ~/.ssh/config every time it starts. Template it here so chezmoi owns it
     and drift stops blocking auto-deploy. */ -}}
{{ if stat (joinPath .chezmoi.homeDir ".config/colima/ssh_config") -}}
Include {{ joinPath .chezmoi.homeDir ".config/colima/ssh_config" }}

{{ end -}}
# SSH Config — managed by chezmoi
# Machine: {{ .machine }} ({{ .chezmoi.hostname }})

{{ if eq .machine "mac" -}}
# Homelab via Tailscale (always-on, no LAN probe needed)
# HostName is the AdGuard-authoritative name (leonardoacosta.dev, split-DNS'd
# to AdGuard via the tailnet resolver, hl-oz6) rather than the raw Tailscale
# MagicDNS FQDN -- accepted tradeoff vs the open AdGuard reliability bug
# (hl-lcw): consistent naming everywhere over resilience to an AdGuard outage.
Host homelab
    HostName homelab.leonardoacosta.dev
    User nyaptor
    IdentityFile ~/.ssh/id_ed25519

{{ else if eq .machine "homelab" -}}
Host mac
    HostName mac.leonardoacosta.dev
    User leonardoacosta
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ConnectTimeout 10

{{ end -}}
# CloudPC via Tailscale (all machines)
Host cloudpc
    HostName cpc.leonardoacosta.dev
    User leo
    IdentityFile ~/.ssh/id_ed25519

# Global settings
Host *
    SendEnv LANG LC_*
    # TERM propagated by terminal emulator (Ghostty sends xterm-ghostty)
    # Requires xterm-ghostty terminfo on remote — install via: ghostty +show-terminfo | tic -x -
    AddKeysToAgent yes
    ServerAliveInterval 30
    ServerAliveCountMax 3
    ConnectionAttempts 2
    ConnectTimeout 10
    # Connection multiplexing (2026-07-19): paste-image.sh's SSH+Ghostty branch opens
    # up to 5 separate ssh/scp calls to the same host per single image paste (CWD
    # resolve, project-root walk, mkdir, scp, tmux inject) — each paying a full
    # handshake+auth cost independently. ControlMaster lets calls 2-5 reuse the first
    # call's already-authenticated connection instead of renegotiating every time.
    # Matters most while the Mac<->homelab Tailscale link is DERP-relayed (dfw) rather
    # than direct — handshake latency is the one part of that we can still cut locally.
    ControlMaster auto
    ControlPath ~/.ssh/control-%r@%h:%p
    ControlPersist 10m
