#!/usr/bin/env bash
# run_onchange_mac-sudo-timeout.sh - extend sudo's credential cache (Mac only)
#
# Re-runs whenever the backing script or this wrapper changes.
# Hash: {{ output "sh" "-c" (printf "sha256sum < %q | awk '{print $1}'" (joinPath .chezmoi.workingTree "scripts/mac-sudo-timeout.sh")) | trim }}
#
# Installs /etc/sudoers.d/local-timestamp: timestamp_timeout=1440 (24h) +
# timestamp_type=global (shared across terminals/tmux panes, not per-tty).
#
# Gated on .machine == "mac" (see home/.chezmoi.toml.tmpl). On homelab/cloudpc
# this file expands to a no-op stub and exits immediately.
#
# The live logic lives in scripts/mac-sudo-timeout.sh so it's:
#   - readable outside the template layer
#   - runnable ad-hoc from the repo (e.g. for testing or manual re-apply)
#   - consistent with run_onchange_mac-autofs-dev.sh.tmpl's wrapper convention

{{ if ne .machine "mac" -}}
# Non-mac machine ({{ .machine }}) — nothing to do.
exit 0
{{- else -}}
set -uo pipefail

DOTFILES="{{ .chezmoi.workingTree }}"
export DOTFILES

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "mac-sudo-timeout: not macOS, skipping (machine={{ .machine }})" >&2
    exit 0
fi

SUDO_TIMEOUT_SCRIPT="$DOTFILES/scripts/mac-sudo-timeout.sh"
if [[ ! -x "$SUDO_TIMEOUT_SCRIPT" ]]; then
    if [[ -f "$SUDO_TIMEOUT_SCRIPT" ]]; then
        chmod +x "$SUDO_TIMEOUT_SCRIPT"
    else
        echo "mac-sudo-timeout: $SUDO_TIMEOUT_SCRIPT not found" >&2
        exit 1
    fi
fi

exec "$SUDO_TIMEOUT_SCRIPT"
{{- end }}
