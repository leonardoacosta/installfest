# Ghostty Configuration
# Managed by chezmoi: ~/.config/ghostty/config

# === Font ===
# Matches Cursor/VS Code's terminal.integrated.font* (shared/vscode-user-settings.json) so the
# editor and terminal render the same typeface/weight. Regular + no thicken: font-thicken is a
# macOS CoreText hack that synthetically widens glyph strokes -- stacked on the old DemiBold
# style, it was the main source of the "colors bleed" complaint (smeared/thickened edges, not
# an actual color issue).
font-family = JetBrainsMono Nerd Font
font-style = Regular
font-size = 13
font-thicken = false

# === Theme / Appearance ===
{{ if eq .theme "nord" -}}
theme = Nord
background = 2E3440
{{- else if eq .theme "one-hunter-vercel" -}}
theme = One-Hunter-Vercel
background = 000000
{{- else if eq .theme "vercel" -}}
theme = Vercel
background = 000000
{{- else if eq .theme "tokyo-night-abyss" -}}
theme = Tokyo-Night-Abyss
{{- else if eq .theme "tokyo-night" -}}
theme = Tokyo-Night
{{- else -}}
theme = {{ .theme | title }}
{{- end }}
# Any value < 1.0 blends with whatever's behind the window (macOS vibrancy defaults blue-gray in
# Dark Mode) -- true #000 is only guaranteed at 1.0. Trying 0.85 (up from 0.80) to cut the tint
# further while keeping some frosted-glass look. Bump to 1.0 (drop blur too) if it still bothers you.
background-opacity = 0.85
background-blur-radius = 20
window-decoration = true
macos-titlebar-style = tabs
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
# srgb, not display-p3: theme hex values (#43AAF9 etc.) are authored in sRGB. Rendering them
# directly in the wider P3 gamut without conversion oversaturates high-sat accents -- the other
# half of the "colors bleed" complaint alongside the font-thicken fix above.
window-colorspace = srgb

# === Behavior ===
confirm-close-surface = false
auto-update = check
copy-on-select = clipboard
mouse-hide-while-typing = true
# Default (true) forwards shift-click to tmux instead of letting Ghostty open
# the URL under the cursor, so a plain Cmd+Click on a link inside a tmux pane
# (mouse on, tmux.conf.tmpl) does nothing. Disabling lets Ghostty intercept
# Shift+Cmd+Click to open the link itself -- bare Cmd+Click parity (iTerm2-style)
# is a confirmed open Ghostty limitation, no fix available (ghostty-org/ghostty
# discussion #8748). No existing shift+click tmux binding is lost by this.
mouse-shift-capture = false

# === macOS Specific ===
macos-option-as-alt = true
window-save-state = always

# === Shell Integration ===
shell-integration = zsh
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo

# === Text Editing: macOS standard keybindings ===

# Option+Left/Right: Move word backward/forward
keybind = alt+left=text:\x1bb
keybind = alt+right=text:\x1bf

# Option+Backspace: Delete word backward
keybind = alt+backspace=text:\x1b\x7f

# Cmd+Left/Right: Beginning/End of line
keybind = super+left=text:\x01
keybind = super+right=text:\x05

# Cmd+Backspace: Delete to beginning of line
keybind = super+backspace=text:\x15

# Cmd+Shift+Left/Right: Select to beginning/end of line (tmux copy mode)
keybind = super+shift+left=text:\x1b[60;CMS~
keybind = super+shift+right=text:\x1b[62;CMS~

# Option+Shift+Left/Right: Select word backward/forward (tmux copy mode)
keybind = alt+shift+left=text:\x1b[60;OMS~
keybind = alt+shift+right=text:\x1b[62;OMS~

# === tmux Integration: Browser-like keybindings ===
# These override Ghostty's native tab/split actions and instead send custom
# escape sequences that tmux maps via user-keys (see tmux.conf).
# Format: \x1b[<ascii>;CMD~ for Cmd+key, \x1b[<ascii>;CMS~ for Cmd+Shift+key

# Cmd+T: New tmux window (overrides Ghostty new_tab)
keybind = super+t=text:\x1b[84;CMD~

# Cmd+W: Smart close — pane if multiple, window if single (overrides Ghostty close_surface)
keybind = super+w=text:\x1b[87;CMD~

# Cmd+D: Split pane vertically / right (overrides Ghostty new_split:right)
keybind = super+d=text:\x1b[68;CMD~

# Cmd+Shift+D: Split pane horizontally / below (overrides Ghostty new_split:down)
keybind = super+shift+d=text:\x1b[68;CMS~

# Cmd+K: Clear scrollback (overrides Ghostty clear_screen)
keybind = super+k=text:\x1b[75;CMD~

# Cmd+Shift+[: Previous tmux window
keybind = super+shift+left_bracket=text:\x1b[91;CMS~

# Cmd+Shift+]: Next tmux window
keybind = super+shift+right_bracket=text:\x1b[93;CMS~

# Cmd+1-9: Select tmux window (overrides Ghostty goto_tab)
# Unbind the digit_ variants first, then rebind the number keys
keybind = super+digit_1=unbind
keybind = super+1=text:\x1b[49;CMD~
keybind = super+digit_2=unbind
keybind = super+2=text:\x1b[50;CMD~
keybind = super+digit_3=unbind
keybind = super+3=text:\x1b[51;CMD~
keybind = super+digit_4=unbind
keybind = super+4=text:\x1b[52;CMD~
keybind = super+digit_5=unbind
keybind = super+5=text:\x1b[53;CMD~
keybind = super+digit_6=unbind
keybind = super+6=text:\x1b[54;CMD~
keybind = super+digit_7=unbind
keybind = super+7=text:\x1b[55;CMD~
keybind = super+digit_8=unbind
keybind = super+8=text:\x1b[56;CMD~
keybind = super+9=text:\x1b[57;CMD~
