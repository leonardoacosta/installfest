[Unit]
Description=Mesh + broker heartbeat (Tailscale mac/cloudpc, mx-broker /health, SOCKS tunnel)
Documentation=file:%h/dev/if/openspec/changes/add-auth-resilience-and-hygiene/proposal.md

[Service]
Type=oneshot
ExecStart=/usr/bin/bash %h/dev/if/scripts/mesh-heartbeat.sh
EnvironmentFile=-%h/.env
StandardOutput=append:%h/.local/state/mesh-heartbeat.systemd.log
StandardError=append:%h/.local/state/mesh-heartbeat.systemd.log
Restart=no
