# =============================================================================
# tmux.conf - Browser-like keybindings with One Hunter Vercel theme
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------

# Set prefix to Ctrl+B (default, but explicit)
set -g prefix C-b
unbind C-a

# Enable mouse support
set -g mouse on

# Start windows and panes at 1, not 0 (browser-like)
set -g base-index 1
setw -g pane-base-index 1

# Renumber windows when one is closed
set -g renumber-windows on

# Increase scrollback buffer
set -g history-limit 50000

# Faster key repetition
set -s escape-time 10

# Enable focus events (useful for vim/neovim)
set -g focus-events on

# Enable OSC 52 clipboard (cross-platform, fixes pbcopy on Linux)
set -g set-clipboard on

# Terminal type — use xterm-256color to preserve base terminal behavior.
# tmux-256color introduces tmux-specific escape sequences (alternate cursor modes,
# smcup/rmcup differences) that cause visible mode switching. xterm-256color is
# universally supported and keeps the terminal feeling transparent.
set -g default-terminal "xterm-256color"
set -as terminal-features ',xterm-256color:RGB'
set -as terminal-features ',xterm-ghostty:RGB'

# Let Kitty graphics-protocol escape sequences (chafa -f kitty, used by
# scripts/view.sh's image renderer) pass through tmux to Ghostty instead of
# being filtered. Ghostty decodes Kitty natively but refuses Sixel permanently,
# so this is the only in-terminal true-raster image path (if-dc4).
set -g allow-passthrough on

# Activity monitoring
setw -g monitor-activity off
set -g visual-activity off

# Window title control — only claude-tab sets titles (via tmux rename-window)
setw -g automatic-rename off
set -g allow-rename off

# -----------------------------------------------------------------------------
# User-Defined Keys (Custom escape sequences from WezTerm)
# Format: \e[<ascii>;CMD~ for Cmd+key, \e[<ascii>;CMS~ for Cmd+Shift+key
# -----------------------------------------------------------------------------

# Cmd+T: New window
set -s user-keys[0] "\e[84;CMD~"
bind-key -n User0 new-window -c "#{pane_current_path}"

# Cmd+W: Smart close (pane if multiple, window if single pane)
set -s user-keys[1] "\e[87;CMD~"
bind-key -n User1 if-shell '[ #{window_panes} -gt 1 ]' 'kill-pane' 'kill-window'

# Cmd+1-9: Switch to window
set -s user-keys[2] "\e[49;CMD~"
bind-key -n User2 select-window -t 1

set -s user-keys[3] "\e[50;CMD~"
bind-key -n User3 select-window -t 2

set -s user-keys[4] "\e[51;CMD~"
bind-key -n User4 select-window -t 3

set -s user-keys[5] "\e[52;CMD~"
bind-key -n User5 select-window -t 4

set -s user-keys[6] "\e[53;CMD~"
bind-key -n User6 select-window -t 5

set -s user-keys[7] "\e[54;CMD~"
bind-key -n User7 select-window -t 6

set -s user-keys[8] "\e[55;CMD~"
bind-key -n User8 select-window -t 7

set -s user-keys[9] "\e[56;CMD~"
bind-key -n User9 select-window -t 8

set -s user-keys[10] "\e[57;CMD~"
bind-key -n User10 select-window -t 9

# Cmd+Shift+[: Previous window
set -s user-keys[11] "\e[91;CMS~"
bind-key -n User11 previous-window

# Cmd+Shift+]: Next window
set -s user-keys[12] "\e[93;CMS~"
bind-key -n User12 next-window

# Cmd+D: Split pane vertically (right)
set -s user-keys[13] "\e[68;CMD~"
bind-key -n User13 split-window -h -c "#{pane_current_path}"

# Cmd+Shift+D: Split pane horizontally (below)
set -s user-keys[14] "\e[68;CMS~"
bind-key -n User14 split-window -v -c "#{pane_current_path}"

# Cmd+K: Clear scrollback
set -s user-keys[15] "\e[75;CMD~"
bind-key -n User15 send-keys -R \; clear-history

# -----------------------------------------------------------------------------
# TRIAL: Scrollback-to-pager binding (started 2026-04-23)
# -----------------------------------------------------------------------------
# Problem: Claude Code's inline TUI repaints corrupt tmux scrollback when
# scrolling via mouse wheel over SSH — history appears "chopped" because
# tmux records CC's redraws instead of the actual transcript.
#
# Fix: Prefix + C-p captures the raw pane buffer (up to 50k lines) and opens
# it in less in a new window. Pager renders cleanly, no repaint pollution.
# Exit with `q` to return. Capture file scoped per session+window to avoid
# clobbering parallel captures.
#
# Trial review: if still used after ~2 weeks, promote to permanent and drop
# the TRIAL header. If unused/awkward, remove block and revert to default
# wheel-scrolling workflow.
# -----------------------------------------------------------------------------
bind C-p capture-pane -pS -50000 \; save-buffer /tmp/tmux-capture-#S-#I \; \
  new-window -n "scrollback" "less -R +G /tmp/tmux-capture-#S-#I"

# Cmd+Shift+Left: Select to beginning of line
set -s user-keys[16] "\e[60;CMS~"
bind-key -n User16 copy-mode \; send-keys -X begin-selection \; send-keys -X start-of-line

# Cmd+Shift+Right: Select to end of line
set -s user-keys[17] "\e[62;CMS~"
bind-key -n User17 copy-mode \; send-keys -X begin-selection \; send-keys -X end-of-line

# Option+Shift+Left: Select word backward
set -s user-keys[18] "\e[60;OMS~"
bind-key -n User18 copy-mode \; send-keys -X begin-selection \; send-keys -X previous-word

# Option+Shift+Right: Select word forward
set -s user-keys[19] "\e[62;OMS~"
bind-key -n User19 copy-mode \; send-keys -X begin-selection \; send-keys -X next-word-end

# -----------------------------------------------------------------------------
# Traditional Prefix Bindings (as backup)
# -----------------------------------------------------------------------------

# Reload config
bind r source-file ~/.config/tmux/tmux.conf \; display-message "Config reloaded!"

# Split panes (traditional)
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Pane navigation with vim keys
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# Pane resizing with vim keys
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# Window navigation
bind -r C-h previous-window
bind -r C-l next-window

# Create new window
bind c new-window -c "#{pane_current_path}"

# Swap windows (move tabs left/right)
bind -r < swap-window -t -1\; select-window -t -1
bind -r > swap-window -t +1\; select-window -t +1

# -----------------------------------------------------------------------------
# Copy Mode (vi keys)
# -----------------------------------------------------------------------------

setw -g mode-keys vi
bind -T copy-mode-vi v send-keys -X begin-selection
bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "pbcopy"

# Enter copy mode
bind [ copy-mode
bind -n PageUp copy-mode -u

# Half-page scroll (Voyager firmware remaps Page Up/Down to Ctrl+U/Ctrl+D —
# see poulainpi/oryx-with-custom-qmk keymap.c, LCTL(KC_U)/LCTL(KC_D)).
# No bind-key needed here: tmux's own copy-mode-vi defaults already map
# C-u -> halfpage-up and C-d -> halfpage-down (verified: `tmux list-keys -T
# copy-mode-vi`, tmux 3.6a) — it's PPage/NPage that default to full page-up/
# page-down, which is the behavior being replaced by the firmware remap.
#
# CAVEAT: the root `bind -n PageUp copy-mode -u` above only fires while the
# keyboard still emits a literal PageUp keycode. If the Voyager key that used
# to send KC_PGUP is repointed to LCTL(KC_U), this binding goes dead (no more
# raw "PageUp" event to trigger it) — the quick jump-into-scrollback shortcut
# is lost unless a different physical key still sends KC_PGUP, or `prefix +
# [` (line above, `bind [ copy-mode`) is used instead as the entry point.

# Scroll speed — 3 lines per tick (default 5)
bind -T copy-mode-vi WheelUpPane   send-keys -X -N 3 scroll-up
bind -T copy-mode-vi WheelDownPane send-keys -X -N 3 scroll-down

# -----------------------------------------------------------------------------
# Plugins (manual install, no TPM — see docs/audit/tmux.md N5)
# -----------------------------------------------------------------------------

# tmux-which-key: popup action menu (prefix+space / Ctrl+Space), installed by
# run_onchange_after_install-tmux-which-key.sh.tmpl into ~/.tmux/plugins/.
# Guarded with if-shell so a fresh machine that hasn't run chezmoi's install
# script yet doesn't fail to load the rest of this config.
if-shell "test -f ~/.tmux/plugins/tmux-which-key/plugin.sh.tmux" \
  "run-shell ~/.tmux/plugins/tmux-which-key/plugin.sh.tmux"

# cc-tmux: Claude Code session tracker / hop / usage (apps/cc-tmux, installed by
# run_onchange_after_install-cc-tmux.sh.tmpl). if-shell guard mirrors which-key.
if-shell "test -f ~/.tmux/plugins/cc-tmux/cc-tmux.tmux" \
  "run-shell ~/.tmux/plugins/cc-tmux/cc-tmux.tmux"

# tmux-sidebar: toggleable file-tree pane (prefix+Tab; prefix+Bspace to open
# focused), installed by run_onchange_after_install-tmux-sidebar.sh.tmpl.
#
# ORDERING: unlike the @cc-* block below, these options MUST be set BEFORE the
# run-shell that sources the plugin. sidebar.tmux reads them ONCE at load to
# compose the argument string it stores in @sidebar-key-<key> and binds; it
# never re-reads them per-toggle, so an option set after the run-shell is
# silently ignored until the next config reload.
#
# @sidebar-tree-position: the plugin's own default is already 'left'
# (scripts/variables.sh TREE_POSITION), but the documented knob is framed as
# opt-in-to-right (docs/options.md), so pin it — left placement is load-bearing
# here, not incidental.
set -g @sidebar-tree-position 'left'
# @sidebar-tree-command: the listing command, run with cwd == the tracked pane's
# path and piped into @sidebar-tree-pager. `tree` has a single global -L depth,
# so the wrapper composes two invocations (shallow root + deep openspec/changes)
# — see scripts/tmux-sidebar-tree.sh.
set -g @sidebar-tree-command '~/.local/bin/tmux-sidebar-tree'
set -g @sidebar-tree-width '45'
if-shell "test -f ~/.tmux/plugins/tmux-sidebar/sidebar.tmux" \
  "run-shell ~/.tmux/plugins/tmux-sidebar/sidebar.tmux"

# tmux-resurrect: save/restore window & pane layout + cwd across a server crash
# or reboot (prefix+Ctrl-s save, prefix+Ctrl-r restore), installed by
# run_onchange_after_install-tmux-resurrect.sh.tmpl into ~/.tmux/plugins/.
# if-shell guard mirrors which-key/cc-tmux so a fresh machine that hasn't run
# chezmoi's install script yet still loads the rest of this config.
if-shell "test -f ~/.tmux/plugins/tmux-resurrect/resurrect.tmux" \
  "run-shell ~/.tmux/plugins/tmux-resurrect/resurrect.tmux"

# cc-tmux config: window tab = <project-code>:<session-title>, truncated to 20
# chars combined (cc-tmux-rename-fix-and-truncate, 2026-07-12 — was 10). Read
# fresh on every register (state change), so this survives a `tmux kill-server`
# + relaunch instead of only living in the running server's option table (see
# skills/cc-config/SKILL.md for the full @cc-* option table).
set -g @cc-window-rename on
set -g @cc-window-rename-format title

# cc-tmux-subagent-tab-icon: how long a background subagent dispatch keeps
# showing its tab-icon glyph (◇/◆) after launch with no further hook signal —
# background dispatches have no reliable "stop" event, so this timeout is the
# only cleanup mechanism (aged out lazily on every read, see
# prune_background_entries in cli.py). Default matches cc_tmux's own
# _subagent_bg_timeout() fallback (300s / 5min) — override here only if that
# default is genuinely wrong for your workflow, not as a first resort.
set -g @cc-subagent-bg-timeout 300

# -----------------------------------------------------------------------------
# Status Bar - Tab-like Appearance
# -----------------------------------------------------------------------------

# Status bar position
set -g status-position bottom

# Status bar update interval — 1s (tmux's floor) drives the cc-tmux animated
# tab icon (re-evaluated via the status-format[0] tabs-row job below); also
# refreshes the credential status segment.
set -g status-interval 1

# Status bar justification
set -g status-justify left

# Three-line status bar: row 1 is the window-tabs line, defined repo-wide
# below via status-format[0] (cc-tmux render-all) — it replaces tmux's native
# per-window setw-based tab-rendering mechanism, confirmed broken on this
# tmux version (jobs nested inside it never execute). Rows 2 and 3 are
# published by this SAME job as the @cc-row-session / @cc-row-beads global
# options (plan 005: one interpreter spawn per tick instead of three) and
# consumed per-theme via status-format[1]/[2] as bare #{@cc-row-*} lookups —
# zero extra processes for rows 2/3. A theme that leaves status 3 on without
# defining both extra rows falls back to tmux's default pane-list row.
set -g status 3

# Row 1 (render-all): entire window-tabs list (icon + index + name per window,
# active-window highlighting) rendered as one string by cc-tmux render-all,
# which ALSO writes rows 2/3 into @cc-row-session / @cc-row-beads as a side
# effect (render TRANSPORT, not state — see cli.py cmd_render_all). Repo-wide
# default, not per-theme — the job's output carries its own fixed CYAN/DIM
# palette internally (same precedent as rows 2/3, which also use a fixed
# palette regardless of active theme), so no #[bg=...] wrapper here.
set -g status-format[0] "#(~/.tmux/plugins/cc-tmux/bin/cc-tmux render-all #{window_id} #{client_width} #{client_height})"

# Row 4 (cc-tmux-row4-session-title): the SAME render-all job above also
# publishes @cc-row-agents — the focused window's tracked-pane session title
# (foreground-only) or a per-sub-agent glyph strip (background dispatches in
# flight). It occupies status-format[N+2] where N == @cc-tab-rows (the theme
# files' own computed-index conditionals, see their "Portrait multi-row"
# comment blocks) and grows `status` to N+2+1 (still capped at 5) ONLY when
# @cc-row-agents is nonempty — omitted entirely (row dropped, `status` stays
# N+2) when there is neither a title nor sub-agent activity. At the portrait
# 3-row tab-wrap cap (N==3, `status` already at the 5-line ceiling), the
# agents row is ALWAYS dropped first so session/beads keep their physical
# rows — render-all forces @cc-row-agents empty in that case regardless of
# content, never grows `status` past 5. The `status 3` line above is
# unaffected by any of this: it is only the static landscape-with-no-agents-
# content fallback (and the pre-render-job default for a stale client);
# render-all owns the live count on every tick via direct `set-option -g
# status` writes (see cli.py's _publish_multirow_status / cmd_render_all).

# Theme: {{ .theme }}
# To add themes: create ~/.config/tmux/<theme>-theme.conf and update .chezmoi.toml.tmpl
source-file ~/.config/tmux/{{ .theme }}-theme.conf
