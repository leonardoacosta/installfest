# Upstash MCP server credentials — consumed by upstash-mcp.service via EnvironmentFile.
# Copy this to `env` (same dir) and fill in real values. The real `env` is gitignored
# and chezmoi-IGNORED — it must NEVER be committed. Obtain values from the Upstash console
# (https://console.upstash.com/account/api) under your account API key settings.
#
#   cp env.example env && chmod 600 env && $EDITOR env
#   systemctl --user restart upstash-mcp.service
UPSTASH_EMAIL=you@example.com
UPSTASH_API_KEY=replace-with-upstash-api-key
