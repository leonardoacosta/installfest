# Machine-local overlay for b-and-b workspace.
# Rendered by chezmoi — never committed. Sources the OS-coupled tunnel ensure-block.
# ALL output redirected — this file is sourced inside the eval'd `wsenv --activate`,
# so any stdout chatter would corrupt the activation shell.

# Ensure the cloudpc SOCKS5 tunnel (127.0.0.1:1080) is up.
# Idempotent + quiet: skip if :1080 already listening, else start the service.
if ! lsof -i :1080 >/dev/null 2>&1; then
{{ if eq .chezmoi.os "linux" -}}
  systemctl --user start cloudpc-tunnel.service >/dev/null 2>&1 || true
{{- else if eq .chezmoi.os "darwin" -}}
  launchctl kickstart "gui/$(id -u)/com.leonardoacosta.cloudpc-tunnel" >/dev/null 2>&1 || true
{{- end }}
fi
