#!/usr/bin/env zsh
# VS Code wrapper — this dotfile is chezmoi-applied on every machine (Mac client AND
# the Linux/homelab remote target), so it must behave differently on each:
#   - On the machine with the real VS Code install (the client), delegate straight to
#     the real `code` binary — this file must never shadow the native CLI.
#   - On a remote host with no local VS Code install, ssh back to the client and
#     trigger `code --remote ssh-remote+<this-host>` there — VS Code's Remote-SSH
#     extension auto-starts vscode-server and opens the window, no manual
#     "Connect via SSH" step needed first.

self="${0:A}"
for candidate in ${(f)"$(whence -ap code 2>/dev/null)"}; do
  [[ "$candidate" == "$self" ]] && continue
  exec "$candidate" "$@"
done

# No local VS Code install — trigger the client's real `code` over SSH.
CLIENT_HOST="${EDITOR_REMOTE_CLIENT:-mac}"
REMOTE_ALIAS="${EDITOR_REMOTE_ALIAS:-$(hostname)}"

target_path="$PWD"
for a in "$@"; do
  [[ "$a" != -* ]] && { target_path="${a:A}"; break; }
done

ssh -o BatchMode=yes -o ConnectTimeout=5 "$CLIENT_HOST" \
  "code --remote ssh-remote+$REMOTE_ALIAS '$target_path'"
rc=$?
[[ $rc -ne 0 ]] && echo "error: could not reach $CLIENT_HOST to auto-open VS Code" >&2
exit $rc
