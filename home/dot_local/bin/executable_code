#!/usr/bin/env zsh
# VS Code wrapper — this dotfile is chezmoi-applied on every machine (Mac client AND
# the Linux/homelab remote target), so it must behave differently on each:
#   - On the machine with the real VS Code install (the client), delegate straight to
#     the real `code` binary — this file must never shadow the native CLI.
#   - On a remote host with no local VS Code install, attach to the connected remote-cli
#     session so `code .` works from an SSH terminal, not just VS Code's integrated one.

self="${0:A}"
for candidate in ${(f)"$(whence -ap code 2>/dev/null)"}; do
  [[ "$candidate" == "$self" ]] && continue
  exec "$candidate" "$@"
done

# No other `code` binary on this host — remote-cli fallback (server side).
# VS Code's remote-server layout differs from Cursor's: cli/servers/Stable-<commit>/
# server/bin/remote-cli, not bin/linux-x64/<version>/bin/remote-cli.
code_cli=("$HOME"/.vscode-server/cli/servers/Stable-*/server/bin/remote-cli(Nom[1])) 2>/dev/null
if [[ ! -x "$code_cli/code" ]]; then
  echo "error: vscode-server not installed (no remote-cli found)" >&2
  exit 1
fi

# IPC sockets go stale (owning window closed) but the file lingers — mtime-newest
# isn't always live, so try each candidate, newest first, until one connects.
socks=(/run/user/$(id -u)/vscode-ipc-*.sock(Nom))
if [[ ${#socks[@]} -eq 0 ]]; then
  echo "error: no VS Code IPC socket found — is VS Code connected via SSH?" >&2
  exit 1
fi

for sock in "${socks[@]}"; do
  out=$(VSCODE_IPC_HOOK_CLI="$sock" "$code_cli/code" "$@" 2>&1)
  rc=$?
  if [[ $rc -eq 0 || "$out" != *ECONNREFUSED* ]]; then
    [[ -n "$out" ]] && print -r -- "$out"
    exit $rc
  fi
done
echo "error: no live VS Code IPC socket found (${#socks[@]} stale)" >&2
exit 1
