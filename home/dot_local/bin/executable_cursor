#!/usr/bin/env zsh
# Cursor wrapper — this dotfile is chezmoi-applied on every machine (Mac client AND
# the Linux/homelab remote target), so it must behave differently on each:
#   - On the machine with the real Cursor install (the client), delegate straight to
#     the real `cursor` binary — this file must never shadow the native CLI.
#   - On a remote host with no local Cursor install, ssh back to the client and
#     trigger `cursor --remote ssh-remote+<this-host>` there — Cursor's Remote-SSH
#     extension auto-starts cursor-server and opens the window, no manual
#     "Connect via SSH" step needed first.

self="${0:A}"
for candidate in ${(f)"$(whence -ap cursor 2>/dev/null)"}; do
  [[ "$candidate" == "$self" ]] && continue
  exec "$candidate" "$@"
done

# No local Cursor install — trigger the client's real `cursor` over SSH.
CLIENT_HOST="${EDITOR_REMOTE_CLIENT:-mac}"
REMOTE_ALIAS="${EDITOR_REMOTE_ALIAS:-$(hostname)}"

target_path="$PWD"
for a in "$@"; do
  [[ "$a" != -* ]] && { target_path="${a:A}"; break; }
done

ssh -o BatchMode=yes -o ConnectTimeout=5 "$CLIENT_HOST" \
  "cursor --remote ssh-remote+$REMOTE_ALIAS '$target_path'"
rc=$?
[[ $rc -ne 0 ]] && echo "error: could not reach $CLIENT_HOST to auto-open Cursor" >&2
exit $rc
