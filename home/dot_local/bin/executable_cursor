#!/usr/bin/env zsh
# Cursor wrapper — this dotfile is chezmoi-applied on every machine (Mac client AND
# the Linux/homelab remote target), so it must behave differently on each:
#   - On the machine with the real Cursor.app install (the client), delegate straight
#     to the real `cursor` binary — this file must never shadow the native CLI.
#   - On a remote host with no local Cursor install, attach to the connected remote-cli
#     session so `cursor .` works from an SSH terminal, not just Cursor's integrated one.

self="${0:A}"
for candidate in ${(f)"$(whence -ap cursor 2>/dev/null)"}; do
  [[ "$candidate" == "$self" ]] && continue
  exec "$candidate" "$@"
done

# No other `cursor` binary on this host — remote-cli fallback (server side).
cursor_cli=("$HOME"/.cursor-server/bin/linux-x64/*/bin/remote-cli(Nom[1])) 2>/dev/null
if [[ ! -x "$cursor_cli/cursor" ]]; then
  echo "error: cursor-server not installed (no remote-cli found)" >&2
  exit 1
fi

# IPC sockets go stale (owning window closed) but the file lingers — mtime-newest
# isn't always live, so try each candidate, newest first, until one connects.
socks=(/run/user/$(id -u)/vscode-ipc-*.sock(Nom))
if [[ ${#socks[@]} -eq 0 ]]; then
  echo "error: no Cursor IPC socket found — is Cursor connected via SSH?" >&2
  exit 1
fi

for sock in "${socks[@]}"; do
  out=$(VSCODE_IPC_HOOK_CLI="$sock" "$cursor_cli/cursor" "$@" 2>&1)
  rc=$?
  if [[ $rc -eq 0 || "$out" != *ECONNREFUSED* ]]; then
    [[ -n "$out" ]] && print -r -- "$out"
    exit $rc
  fi
done
echo "error: no live Cursor IPC socket found (${#socks[@]} stale)" >&2
exit 1
