#!/usr/bin/env python3
"""
vercel-trim: token-optimized wrapper around `vercel` CLI for LLM context.

Trims:
  - "Fetching..." / "> Fetched in [Nms]" progress lines
  - Repeated team prefix ("priceless-dev/") in deployment tables
  - Trailing whitespace + collapse 3+ space runs to 2
  - Duplicate URL-list block appended after table when piping `ls`
  - <claude-code-hint .../> plugin injection from CC hooks

Subcommand-specific:
  - `ls` / `project ls`: default --limit 5 (overridable); drops pagination hint
  - `inspect`: truncates Builds tree to first 5 items

Empirical baseline (eval 2026-05-16): 57% reduction vs raw vercel CLI on 10 ops,
projected savings ~367k tokens/60d at current usage rates.
"""
from __future__ import annotations
import subprocess, sys, re

PROGRESS_RE = re.compile(r'^(Fetching|> Fetched|> Projects found|> Deployments for|> Inspect|> To display).*$', re.M)
TIMING_RE   = re.compile(r'\s*\[\d+(?:\.\d+)?(?:ms|s)\]\s*')
TEAM_PREFIX = re.compile(r'\bpriceless-dev/')
TRAILING_WS = re.compile(r'[ \t]+$', re.M)
MULTI_WS    = re.compile(r' {3,}')

def is_ls_command(args: list[str]) -> bool:
    return len(args) >= 1 and args[0] == 'ls'

def limit_ls(text: str, limit: int) -> str:
    """Keep header + first N data rows; truncate the rest with a footer."""
    lines = text.splitlines()
    header_idx = None
    data_lines: list[str] = []
    other: list[str] = []
    for line in lines:
        if header_idx is None:
            other.append(line)
            if re.match(r'^\s*(Age|Project Name|id)\s', line):
                header_idx = 1
        elif re.match(r'^\s{2,}\S', line):
            data_lines.append(line)
        else:
            other.append(line)
    kept = data_lines[:limit]
    truncated = max(0, len(data_lines) - limit)
    result = [l for l in other if not PROGRESS_RE.match(l)] + kept
    if truncated:
        result.append(f"  ... [{truncated} more rows truncated; use --limit to see all]")
    return '\n'.join(result)

def truncate_builds_section(text: str, keep: int = 5) -> str:
    """In `vercel inspect`, the Builds tree dumps every output item. Keep first N."""
    out: list[str] = []
    in_builds = False
    build_count = 0
    for line in text.splitlines():
        if re.match(r'^\s*Builds\s*$', line):
            in_builds = True; build_count = 0
            out.append(line); continue
        if in_builds and re.match(r'^\s*[├└][─┬]', line):
            build_count += 1
            if build_count <= keep:
                out.append(line)
            elif build_count == keep + 1:
                out.append(f"    └── [{keep}+ items truncated]")
            continue
        if in_builds and not line.strip():
            in_builds = False
        out.append(line)
    return '\n'.join(out)

def drop_url_list_after_table(text: str) -> str:
    """When `vercel ls` is piped, it appends a plain URL list after the table — dedupe."""
    lines = text.splitlines()
    url_block_start = None
    for i in range(len(lines) - 1, -1, -1):
        s = lines[i].strip()
        if not s: continue
        if re.match(r'^https?://\S+$', s):
            url_block_start = i
        elif url_block_start is not None:
            break
    if url_block_start is not None:
        has_table = any(re.match(r'^\s+(Age|Project Name)\s', l) for l in lines[:url_block_start])
        if has_table:
            return '\n'.join(lines[:url_block_start])
    return text

def trim(text: str, args: list[str]) -> str:
    if is_ls_command(args):
        text = drop_url_list_after_table(text)
    text = PROGRESS_RE.sub('', text)
    text = TIMING_RE.sub('', text)
    text = TEAM_PREFIX.sub('', text)
    text = TRAILING_WS.sub('', text)
    text = MULTI_WS.sub('  ', text)
    text = re.sub(r'\n{3,}', '\n\n', text)
    limit = 5
    if '--limit' in args:
        try: limit = int(args[args.index('--limit') + 1])
        except (ValueError, IndexError): pass
    if is_ls_command(args):
        text = limit_ls(text, limit)
    if len(args) >= 1 and args[0] == 'inspect':
        text = truncate_builds_section(text, keep=5)
    return text.strip() + '\n'

def main() -> None:
    args = sys.argv[1:]
    # Strip wrapper-only flags from what we forward (vercel CLI doesn't know --limit)
    fwd = list(args)
    if '--limit' in fwd:
        idx = fwd.index('--limit')
        fwd = fwd[:idx] + fwd[idx + 2:]
    result = subprocess.run(['vercel'] + fwd, capture_output=True, text=True)
    # Preserve write-order: vercel writes table to stderr, URLs to stdout
    out = result.stderr + result.stdout
    out = re.sub(r'<claude-code-hint[^>]*/>\s*\n?', '', out)
    print(trim(out, args), end='')
    sys.exit(result.returncode)

if __name__ == '__main__':
    main()
