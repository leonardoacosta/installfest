#!/usr/bin/env bash
# copen — open (or focus) the Mac's Cursor window for a registry project.
#
# Usage:
#   copen                  CWD -> registry project -> Remote-SSH window on the Mac
#   copen ws               by registry code
#   copen docs/readme.md   open that file directly (project inferred from the file)
#   copen -n ...           dry-run (print resolution + ssh command)
#
# Resolution comes from if's project registry (projects.toml): a code arg is
# looked up directly; a path arg (or bare CWD) is matched against registry
# paths, longest prefix wins. Cursor's CLI is single-instance per folder URI:
# already open -> focuses that window, else opens one (launching the app if
# needed). After opening, the window is activated and pushed fullscreen via
# AXFullScreen — the fullscreen step silently no-ops until osascript over ssh
# is granted Accessibility on the Mac (System Settings > Privacy & Security >
# Accessibility: add /usr/sbin/sshd and /usr/bin/osascript).
#
# Env:
#   COPEN_MAC_HOST     ssh alias for the Mac   (default: mac)
#   COPEN_REGISTRY     projects.toml path      (default: ~/projects.toml,
#                                               falling back to $DOTFILES/home/projects.toml)
#   COPEN_FULLSCREEN   set 0 to skip the fullscreen attempt
(return 0 2>/dev/null) || set -euo pipefail

MAC_HOST="${COPEN_MAC_HOST:-mac}"
DOTFILES="${DOTFILES:-$HOME/dev/if}"
REGISTRY="${COPEN_REGISTRY:-$HOME/projects.toml}"
[ -f "$REGISTRY" ] || REGISTRY="$DOTFILES/home/projects.toml"
FULLSCREEN="${COPEN_FULLSCREEN:-1}"

usage() { sed -n '2,25p' "$0" | sed 's/^# \{0,1\}//'; }

DRYRUN=""
TARGET=""
for arg in "$@"; do
  case "$arg" in
    -h|--help) usage; exit 0 ;;
    -n|--dry-run) DRYRUN=1 ;;
    -*) echo "copen: unknown option $arg" >&2; exit 1 ;;
    *) TARGET="$arg" ;;
  esac
done

[ -f "$REGISTRY" ] || { echo "copen: registry not found: $REGISTRY" >&2; exit 1; }

# If the arg is a real path (and not a registry code): a FILE becomes the thing
# to open; a DIRECTORY only anchors project resolution (the project window opens).
FILE_ABS=""
ANCHOR_DIR=""
ARG_CODE="$TARGET"
if [ -n "$TARGET" ] && [ -e "$TARGET" ]; then
  if [ -d "$TARGET" ]; then
    ANCHOR_DIR="$(realpath -- "$TARGET")"
  else
    FILE_ABS="$(realpath -- "$TARGET")"
  fi
  ARG_CODE=""
fi

# Resolve (code, project path, remote host) from the registry. Anchor is the
# file's location when a file was given, else the CWD.
ANCHOR="${FILE_ABS:-${ANCHOR_DIR:-$PWD}}"
RESOLVED="$(python3 - "$REGISTRY" "$ARG_CODE" "$ANCHOR" <<'PY'
import os, sys, tomllib
reg, arg, anchor = sys.argv[1:4]
with open(reg, "rb") as f:
    data = tomllib.load(f)
base = data.get("defaults", {}).get("ssh_base", os.path.expanduser("~"))
remote = data.get("defaults", {}).get("ssh_host", "homelab")
best = None
for p in data.get("projects", []):
    abs_p = os.path.join(base, p["path"])
    if arg:
        if p["code"] == arg:
            best = (p["code"], abs_p)
            break
    elif anchor == abs_p or anchor.startswith(abs_p + os.sep):
        if best is None or len(abs_p) > len(best[1]):
            best = (p["code"], abs_p)
if best is None:
    what = f"code '{arg}'" if arg else f"project containing {anchor}"
    print(f"copen: registry has no {what} ({reg})", file=sys.stderr)
    sys.exit(1)
print(best[0], best[1], remote)
PY
)" || exit 1
read -r CODE ABS REMOTE <<< "$RESOLVED"

# Cursor CLI on the Mac: PATH first (login installs), app bundle fallback —
# BatchMode ssh gets the bare system PATH, which usually lacks /usr/local/bin.
# Folder + optional file in one call: the file opens inside the folder's window.
OPEN_ARGS="'${ABS}'"
[ -n "$FILE_ABS" ] && OPEN_ARGS="$OPEN_ARGS '${FILE_ABS}'"
REMOTE_CMD="CLI=\"/Applications/Cursor.app/Contents/Resources/app/bin/cursor\"; command -v cursor >/dev/null 2>&1 && CLI=cursor; \"\$CLI\" --remote ssh-remote+${REMOTE} ${OPEN_ARGS}; open -a Cursor"
if [ "$FULLSCREEN" = "1" ]; then
  # AXFullScreen needs Accessibility (TCC); no-op until granted. Small sleep so
  # the window exists before the attribute write.
  REMOTE_CMD="$REMOTE_CMD; sleep 1.5; osascript -e 'tell application \"System Events\" to tell process \"Cursor\" to set value of attribute \"AXFullScreen\" of front window to true' >/dev/null 2>&1 || true"
fi

if [ -n "$DRYRUN" ]; then
  echo "[dryrun] project: $CODE  path: $ABS  file: ${FILE_ABS:-<none>}  remote: $REMOTE"
  echo "[dryrun] ssh $MAC_HOST \"$REMOTE_CMD\""
  exit 0
fi

if ! ssh -o BatchMode=yes -o ConnectTimeout=3 "$MAC_HOST" true 2>/dev/null; then
  echo "copen: Mac unreachable ($MAC_HOST)" >&2
  exit 2
fi

# fire-and-forget (mac-open parity): the CLI blocks while the app launches
( ssh -o BatchMode=yes -o ConnectTimeout=5 "$MAC_HOST" "$REMOTE_CMD" >/dev/null 2>&1 & ) 2>/dev/null
if [ -n "$FILE_ABS" ]; then
  echo "copen: $CODE -> ${FILE_ABS#"$ABS"/} ($REMOTE:$ABS) on $MAC_HOST"
else
  echo "copen: $CODE -> Cursor ($REMOTE:$ABS) on $MAC_HOST"
fi
