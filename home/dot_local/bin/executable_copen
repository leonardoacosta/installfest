#!/usr/bin/env bash
# copen — open (or focus) a registry project in Cursor, on the machine copen
# was actually run from.
#
# Usage:
#   copen                  CWD -> registry project -> Cursor, here
#   copen ws               by registry code
#   copen docs/readme.md   open that file directly (project inferred from the file)
#   copen ~/dev/ds/        directory arg anchors the project
#   copen -n ...           dry-run (print resolution + the command that would run)
#
# On the Mac (uname -s == Darwin): opens the LOCAL clone directly — no SSH hop.
# If the clone is missing, it is cloned from the homelab over the ssh mesh (no
# Mac-side ADO/GitHub creds needed), then origin is re-pointed at the homelab
# clone's real upstream. Cursor's CLI is single-instance per folder: already
# open -> focuses, else opens (launching the app if needed). The window is
# then activated and pushed fullscreen via AXFullScreen — a silent no-op until
# the one-time Accessibility grant is made (System Settings > Privacy &
# Security > Accessibility: add /usr/bin/osascript).
#
# Elsewhere (Linux — homelab/Arch): unchanged from the original design —
# still hops through SSH to the Mac and opens the Mac's LOCAL clone there.
# (Opening a genuinely local GUI editor isn't possible here: the `cursor`
# on PATH is the remote-cli/IPC wrapper, which only works when Cursor on the
# Mac is already Remote-SSH-connected into this box — it can't launch Cursor
# from scratch. Making copen open via a fresh Remote-SSH window into whatever
# host it's invoked from, instead of cloning to the Mac, is a bigger mechanism
# change than this fix covers — ask Leo before going further down that path.)
#
# Env:
#   COPEN_MAC_HOST     ssh alias for the Mac   (default: mac)
#   COPEN_REGISTRY     projects.toml path      (default: ~/projects.toml,
#                                               falling back to $DOTFILES/home/projects.toml)
#   COPEN_FULLSCREEN   set 0 to skip the fullscreen attempt
(return 0 2>/dev/null) || set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/dev/personal/installfest}"
[ -r "$DOTFILES/scripts/lib/registry.sh" ] || { echo "copen: registry lib not found: $DOTFILES/scripts/lib/registry.sh" >&2; exit 1; }
# shellcheck source=/dev/null
source "$DOTFILES/scripts/lib/registry.sh"

MAC_HOST="${COPEN_MAC_HOST:-mac}"
REGISTRY="${COPEN_REGISTRY:-$HOME/projects.toml}"
[ -f "$REGISTRY" ] || REGISTRY="$DOTFILES/home/projects.toml"
FULLSCREEN="${COPEN_FULLSCREEN:-1}"
IS_MAC=0
[ "$(uname -s)" = "Darwin" ] && IS_MAC=1

usage() { sed -n '2,29p' "$0" | sed 's/^# \{0,1\}//'; }

DRYRUN=""
TARGET=""
for arg in "$@"; do
  case "$arg" in
    -h|--help) usage; exit 0 ;;
    -n|--dry-run) DRYRUN=1 ;;
    -*) echo "copen: unknown option $arg" >&2; exit 1 ;;
    *) TARGET="$arg" ;;
  esac
done

[ -f "$REGISTRY" ] || { echo "copen: registry not found: $REGISTRY" >&2; exit 1; }

# If the arg is a real path (and not a registry code): a FILE becomes the thing
# to open; a DIRECTORY only anchors project resolution (the project window opens).
FILE_ABS=""
ANCHOR_DIR=""
ARG_CODE="$TARGET"
if [ -n "$TARGET" ] && [ -e "$TARGET" ]; then
  if [ -d "$TARGET" ]; then
    ANCHOR_DIR="$(realpath -- "$TARGET")"
  else
    FILE_ABS="$(realpath -- "$TARGET")"
  fi
  ARG_CODE=""
fi

# Resolve (code, homelab project path, registry rel path, ssh user+host) from
# the registry. Anchor is the file/dir when given, else the CWD.
ANCHOR="${FILE_ABS:-${ANCHOR_DIR:-$PWD}}"
PY="$(registry_python)" || exit 1
RESOLVED="$("$PY" - "$REGISTRY" "$ARG_CODE" "$ANCHOR" <<'PY'
import os, sys, tomllib
reg, arg, anchor = sys.argv[1:4]
with open(reg, "rb") as f:
    data = tomllib.load(f)
d = data.get("defaults", {})
base = d.get("ssh_base", os.path.expanduser("~"))
src = f"{d.get('ssh_user', 'nyaptor')}@{d.get('ssh_host', 'homelab')}"
best = None
best_real_len = -1
anchor_real = os.path.realpath(anchor)
for p in data.get("projects", []):
    abs_p = os.path.join(base, p["path"])
    if arg:
        if p["code"] == arg:
            best = (p["code"], abs_p, p["path"])
            break
    else:
        # realpath: registry entries may point at a symlink (e.g. ~/.claude
        # -> ~/dev/cc); compare against the resolved target so working from
        # either path resolves to the same project.
        abs_p_real = os.path.realpath(abs_p)
        if anchor_real == abs_p_real or anchor_real.startswith(abs_p_real + os.sep):
            if len(abs_p_real) > best_real_len:
                best = (p["code"], abs_p, p["path"])
                best_real_len = len(abs_p_real)
if best is None:
    what = f"code '{arg}'" if arg else f"project containing {anchor}"
    print(f"copen: registry has no {what} ({reg})", file=sys.stderr)
    sys.exit(1)
print(best[0], best[1], best[2], src)
PY
)" || exit 1
read -r CODE HL_ABS REL SRC <<< "$RESOLVED"

# Real upstream of the homelab clone (empty if none) — a fresh clone's origin
# gets re-pointed here so pushes go to the true remote, not the homelab.
# Credentials embedded in the URL (PAT userinfo) are STRIPPED — never copy a
# secret to another machine; the local credential helper handles auth.
ORIGIN="$(git -C "$HL_ABS" remote get-url origin 2>/dev/null | sed -E 's#^(https?://)[^@/]+@#\1#' || true)"

# File path relative to the project root, remapped onto the target clone.
REL_FILE=""
[ -n "$FILE_ABS" ] && REL_FILE="${FILE_ABS#"$HL_ABS"/}"

if [ "$IS_MAC" = "1" ]; then
  # Already on the Mac — open the local clone directly, no SSH hop.
  LOCAL_DIR="$HOME/$REL"
  CLI="/Applications/Cursor.app/Contents/Resources/app/bin/cursor"

  if [ -n "$DRYRUN" ]; then
    echo "[dryrun] project: $CODE  local: $LOCAL_DIR  file: ${REL_FILE:-<none>}  origin: ${ORIGIN:-<keep homelab>}"
    echo "[dryrun] (on Mac — opens directly, no ssh)"
    exit 0
  fi

  if [ ! -d "$LOCAL_DIR/.git" ]; then
    echo "copen: cloning $SRC:$REL -> $LOCAL_DIR"
    mkdir -p "$(dirname "$LOCAL_DIR")"
    git clone "$SRC:$REL" "$LOCAL_DIR" || exit 1
    [ -n "$ORIGIN" ] && git -C "$LOCAL_DIR" remote set-url origin "$ORIGIN"
  fi

  if [ ! -x "$CLI" ]; then
    echo "copen: Cursor.app not found at $CLI" >&2
    exit 1
  fi
  "$CLI" "$LOCAL_DIR"${REL_FILE:+ "$LOCAL_DIR/$REL_FILE"}
  open -a Cursor

  if [ "$FULLSCREEN" = "1" ]; then
    sleep 1.5
    osascript -e 'tell application "System Events" to tell process "Cursor" to set value of attribute "AXFullScreen" of front window to true' >/dev/null 2>&1 || true
  fi
  echo "copen: $CODE -> ${REL_FILE:-Cursor} ($LOCAL_DIR)"
  exit 0
fi

# Not on the Mac (Linux — homelab/Arch): unchanged original behavior — hop
# through SSH and open the Mac's LOCAL clone there. See header comment for why
# this hasn't switched to a Remote-SSH-into-current-host mechanism.
REMOTE_CMD="DIR=\"\$HOME/${REL}\"
if [ ! -d \"\$DIR/.git\" ]; then
  echo \"copen: cloning ${SRC}:${REL} -> \$DIR\"
  mkdir -p \"\$(dirname \"\$DIR\")\"
  git clone \"${SRC}:${REL}\" \"\$DIR\" || exit 1
  [ -n \"${ORIGIN}\" ] && git -C \"\$DIR\" remote set-url origin \"${ORIGIN}\"
fi
# Always the app-bundle CLI: \$PATH \`cursor\` on the Mac is the chezmoi-deployed
# LINUX wrapper (remote-cli/IPC), which errors on macOS.
CLI=\"/Applications/Cursor.app/Contents/Resources/app/bin/cursor\"
\"\$CLI\" \"\$DIR\"${REL_FILE:+ \"\$DIR/${REL_FILE}\"}
open -a Cursor"
if [ "$FULLSCREEN" = "1" ]; then
  REMOTE_CMD="$REMOTE_CMD
sleep 1.5
osascript -e 'tell application \"System Events\" to tell process \"Cursor\" to set value of attribute \"AXFullScreen\" of front window to true' >/dev/null 2>&1 || true"
fi

if [ -n "$DRYRUN" ]; then
  echo "[dryrun] project: $CODE  mac: \$HOME/$REL  file: ${REL_FILE:-<none>}  origin: ${ORIGIN:-<keep homelab>}"
  printf '[dryrun] ssh %s <<SCRIPT\n%s\nSCRIPT\n' "$MAC_HOST" "$REMOTE_CMD"
  exit 0
fi

if ! ssh -o BatchMode=yes -o ConnectTimeout=3 "$MAC_HOST" true 2>/dev/null; then
  echo "copen: Mac unreachable ($MAC_HOST)" >&2
  exit 2
fi

# Synchronous: clone progress/errors must surface.
ssh -o BatchMode=yes "$MAC_HOST" "$REMOTE_CMD"
echo "copen: $CODE -> ${REL_FILE:-Cursor} (\$HOME/$REL on $MAC_HOST)"
