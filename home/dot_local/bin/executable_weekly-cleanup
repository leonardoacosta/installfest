#!/usr/bin/env bash
# Weekly cache cleanup — cross-platform.
# Managed by chezmoi: home/dot_local/bin/executable_weekly-cleanup -> ~/.local/bin/weekly-cleanup
#
# Triggered automatically by:
#   - macOS:  ~/Library/LaunchAgents/com.leonardoacosta.weekly-cleanup.plist
#   - Linux:  ~/.config/systemd/user/weekly-cleanup.timer
# Schedule: Sundays at 03:00 local time.
#
# Scope: caches that the OS / package managers rebuild on demand, PLUS
# regenerable build output under ~/dev (age-gated, see below).
# Explicitly NOT touched:
#   - ~/Library/Application Support  (irreplaceable app state)
#   - node_modules / .git in ~/dev   (breaks active projects / history)
#   - ~/.config                      (deliberate user config)
#   - Xcode simulator runtimes       (judgment call — prune manually)
# DOES touch (new): .turbo / .next / *.bun-build under ~/dev when untouched
#   for >7 days. Active projects rebuild these; stale clones get reclaimed.
#   Also stray Cursor/Electron crash logs in $HOME (*.Default.w*.log, >7d).
#
# Notifications: emits a banner+TTS at start (with bloat snapshot) and at
# finish (with delta) via nexus-agent's UNIX socket. A FAILED/aborted run
# now emits a loud failure banner instead of dying silently (this script
# was a no-op for weeks before that was fixed — see _on_exit trap).
# Bloat radar: also scans adjacent dirs it deliberately does NOT auto-clean
# (Xcode/CoreSimulator runtimes, Claude vm_bundles, colima, .nuget, big
# ~/dev repos) AND runaway Chrome profile History files — the exact silent
# failure that filled the disk — and speaks a dedicated warning if any are
# over threshold. This is the early-warning that was missing.
#
# Run manually: weekly-cleanup [--dry-run]
# Live output:  tail -f ~/.local/state/weekly-cleanup.log

# NOTE: deliberately NOT `set -e` / `set -o pipefail`. A best-effort reaper
# must not abort on the first non-zero cleanup step — every step below is
# guarded with `|| true`. `set -e` + the old `tee` process-substitution is
# exactly what made scheduled runs die after the header with no trace.
set -u

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
	cat <<'EOF'
Usage: weekly-cleanup [--dry-run]

Cross-platform weekly cache cleanup (also triggered by a LaunchAgent/
systemd timer, Sundays 03:00 local). Reaps OS/package-manager caches plus
age-gated build output (.turbo/.next/*.bun-build >7d) under ~/dev. Emits a
banner+TTS notification via nexus-agent at start and finish.

  --dry-run   report what would be cleaned without deleting anything.

Live output: tail -f ~/.local/state/weekly-cleanup.log
EOF
	exit 0
fi

DRY_RUN=0
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=1

LOG_FILE="$HOME/.local/state/weekly-cleanup.log"
HEARTBEAT="$HOME/.local/state/weekly-cleanup.last-success"
mkdir -p "$(dirname "$LOG_FILE")"
# Plain append — NOT `> >(tee …)`. Process substitution drops buffered
# output when launchd reaps the process group on early exit, which is why
# failures were invisible. `tail -f` the log for live output on manual runs.
exec >> "$LOG_FILE" 2>&1

# ── Helpers ───────────────────────────────────────────────────────────
NEXUS_SOCK="/tmp/nexus-agent.sock"

# Emit a banner+TTS event. Best-effort — if the agent isn't running or
# socat is missing, fall through silently. Banners are single-line; the
# script's full output still goes to LOG_FILE for post-mortem.
notify() {
  local msg="$1" title="Weekly cleanup"

  # ── Native banner — guaranteed delivery, OS-bundled, no daemon ──────
  # Independent of the nexus stack, which has historically had stuck-
  # pipe issues that silently drop events. Native APIs surface to macOS
  # Notification Center / Linux libnotify directly.
  case "$(uname -s)" in
    Darwin)
      # osascript escapes: only " and \ matter inside the AppleScript
      # string literal. Use python-style replacement for portability
      # against bash 3.2 (no ${var//pattern/replace} edge cases).
      local osa_msg="${msg//\\/\\\\}"
      osa_msg="${osa_msg//\"/\\\"}"
      /usr/bin/osascript -e "display notification \"$osa_msg\" with title \"$title\"" 2>/dev/null || true
      ;;
    Linux)
      command -v notify-send >/dev/null 2>&1 \
        && notify-send --app-name="weekly-cleanup" "$title" "$msg" 2>/dev/null || true
      ;;
  esac

  # ── Best-effort nexus event for TTS audio ───────────────────────────
  # The agent receives this and broadcasts to the listener for spoken
  # delivery. Banner side may double-display when the listener is
  # healthy — that's acceptable for an audible/visual confirm pair.
  # Trailing \n is the agent's UNIX-socket message framing delimiter.
  if [[ -S "$NEXUS_SOCK" ]] && command -v socat >/dev/null 2>&1; then
    local esc="${msg//\\/\\\\}"
    esc="${esc//\"/\\\"}"
    printf '{"event":"notification","message":"%s"}\n' "$esc" \
      | socat - UNIX-CONNECT:"$NEXUS_SOCK" 2>/dev/null || true
  fi
}

# Format human-readable size from KB. Mirrors `du -h` thresholds so the
# banner reads consistently with the script's per-line output.
human_kb() {
  local kb="$1"
  if   (( kb >= 1048576 )); then printf '%.1fG' "$(bc -l <<<"$kb/1048576")"
  elif (( kb >= 1024    )); then printf '%.0fM' "$(bc -l <<<"$kb/1024")"
  else                            printf '%dK' "$kb"
  fi
}

# Quick `du -sk` wrapper that returns 0 if the path doesn't exist.
size_kb() {
  [[ -d "$1" ]] || { echo 0; return; }
  du -sk "$1" 2>/dev/null | awk '{print $1}'
}

# ── Bloat radar ───────────────────────────────────────────────────────
# Early-warning for adjacent dirs the reaper deliberately does NOT auto-
# delete (judgment-required) but that silently balloon. This detector was
# missing when ~176G of Xcode runtimes + a 1.3G runaway Chrome History
# filled the disk with zero warning. Findings go to the log AND a compact
# list is spoken at end-of-run, with a dedicated loud TTS if anything trips.
# Thresholds are GB (Chrome History is MB — it's the marquee case).
BLOAT_WARN=""
bloat_check() {   # label  path  threshold_gb  hint
  local label="$1" path="$2" thr_gb="$3" hint="$4" kb thr_kb
  [[ -e "$path" ]] || return
  kb=$(du -sk "$path" 2>/dev/null | awk '{print $1}')
  [[ -z "$kb" ]] && return
  thr_kb=$(( thr_gb * 1048576 ))
  if (( kb > thr_kb )); then
    echo "  BLOAT  $label  $(human_kb "$kb") (> ${thr_gb}G) — $hint"
    BLOAT_WARN+="${BLOAT_WARN:+; }$label $(human_kb "$kb")"
  fi
}

bloat_radar() {
  echo "  -- bloat radar (adjacent dirs NOT auto-cleaned) --"
  if [[ "$(uname -s)" == "Darwin" ]]; then
    bloat_check "Xcode/Developer"   "/Library/Developer"                                  50 "xcrun simctl runtime delete <old>"
    bloat_check "CoreSimulator"     "$HOME/Library/Developer/CoreSimulator"               20 "delete unused sim devices"
    bloat_check "iOS DeviceSupport" "$HOME/Library/Developer/Xcode/iOS DeviceSupport"      5 "rm stale device-support dirs"
    bloat_check "Claude vm_bundles" "$HOME/Library/Application Support/Claude/vm_bundles"   3 "rm if not using Claude local-VM"
    bloat_check "colima"            "$HOME/.config/colima"                                  3 "colima delete if unused"
    # Runaway Chrome profile History — the exact failure this all chased.
    local h prof khb
    for h in "$HOME/Library/Application Support/Google/Chrome/"*/History; do
      [[ -f "$h" ]] || continue
      khb=$(du -sk "$h" 2>/dev/null | awk '{print $1}')
      [[ -z "$khb" ]] && continue
      if (( khb > 307200 )); then        # > 300 MB
        prof=$(basename "$(dirname "$h")")
        echo "  BLOAT  Chrome '$prof' History  $(human_kb "$khb") (>300M) — runaway history, inspect/purge"
        BLOAT_WARN+="${BLOAT_WARN:+; }Chrome '$prof' History $(human_kb "$khb")"
      fi
    done
  fi
  bloat_check ".nuget"     "$HOME/.nuget"        8 "nuget locals clear failing?"
  bloat_check "pnpm store" "$HOME/Library/pnpm" 12 "pnpm store prune ineffective?"
  # Oversized ~/dev repos (informational — node_modules-inclusive).
  if [[ -d "$HOME/dev" ]]; then
    local szk path
    while IFS=$'\t' read -r szk path; do
      [[ -z "$szk" ]] && continue
      if (( szk > 8388608 )); then       # > 8 GB
        echo "  BLOAT  dev/$(basename "$path")  $(human_kb "$szk") (>8G) — stale clone / build output?"
        BLOAT_WARN+="${BLOAT_WARN:+; }dev/$(basename "$path") $(human_kb "$szk")"
      fi
    done < <(du -sk "$HOME"/dev/*/ 2>/dev/null)
  fi
  [[ -z "$BLOAT_WARN" ]] && echo "  (clear — nothing over threshold)"
}

# ── Silent-abort guard ────────────────────────────────────────────────
# The old script died after the header on every scheduled run with zero
# diagnostics. This trap guarantees a dead reaper is now LOUD: any exit
# that didn't reach the Phase-3 completion sentinel emits a failure banner.
COMPLETED=0
_on_exit() {
  local rc=$?
  (( COMPLETED == 1 )) && return
  echo "=== ABORTED rc=$rc — did not reach completion sentinel ==="
  notify "Weekly cleanup FAILED (rc=$rc) — aborted before finishing. Check ~/.local/state/weekly-cleanup.log"
}
trap _on_exit EXIT

# ── Phase 1: snapshot bloat BEFORE cleanup ────────────────────────────
echo
echo "=== weekly-cleanup $(date -Iseconds) (dry_run=$DRY_RUN) ==="

START_FREE_KB=$(df -k "$HOME" | tail -1 | awk '{print $4}')
START_FREE_PCT=$(df -k "$HOME" | tail -1 | awk '{print $5}')

XDG_KB=$(size_kb "$HOME/.cache")
LIB_CACHES_KB=$(size_kb "$HOME/Library/Caches")
NPM_KB=$(size_kb "$HOME/.npm")
BUN_KB=$(size_kb "$HOME/.bun/install/cache")
CARGO_KB=$(size_kb "$HOME/.cargo/registry/cache")

# Total reclaimable on this OS
RECLAIMABLE_KB=$((XDG_KB + NPM_KB + BUN_KB))
[[ "$(uname -s)" == "Darwin" ]] && RECLAIMABLE_KB=$((RECLAIMABLE_KB + LIB_CACHES_KB))
[[ "$(uname -s)" == "Linux"  ]] && RECLAIMABLE_KB=$((RECLAIMABLE_KB + CARGO_KB))

echo "  free at start:     $(human_kb "$START_FREE_KB") ($START_FREE_PCT used)"
echo "  xdg-cache:         $(human_kb "$XDG_KB")"
[[ "$(uname -s)" == "Darwin" ]] && echo "  library-caches:    $(human_kb "$LIB_CACHES_KB")"
echo "  npm cache:         $(human_kb "$NPM_KB")"
echo "  bun cache:         $(human_kb "$BUN_KB")"
[[ "$(uname -s)" == "Linux"  ]] && echo "  cargo cache:       $(human_kb "$CARGO_KB")"
echo "  reclaimable est:   $(human_kb "$RECLAIMABLE_KB")"

# Prior-run health: if the last success is missing or >8 days old, the
# reaper was silently broken — surface it instead of letting it rot again.
PRIOR_WARN=""
if [[ ! -f "$HEARTBEAT" ]]; then
  PRIOR_WARN="[NO PRIOR SUCCESS] "
elif [[ -n "$(find "$HEARTBEAT" -mtime +8 2>/dev/null)" ]]; then
  PRIOR_WARN="[LAST SUCCESS >8d AGO] "
fi
[[ -n "$PRIOR_WARN" ]] && echo "  WARN: ${PRIOR_WARN}reaper may have been failing silently"

START_BANNER="${PRIOR_WARN}Weekly cleanup starting"
[[ $DRY_RUN -eq 1 ]] && START_BANNER="${PRIOR_WARN}Weekly cleanup DRY-RUN"
START_BANNER+=" — disk: $(human_kb "$START_FREE_KB") free ($START_FREE_PCT used) · target: ~$(human_kb "$RECLAIMABLE_KB")"
[[ "$(uname -s)" == "Darwin" ]] && \
  START_BANNER+=" (xdg $(human_kb "$XDG_KB") · lib $(human_kb "$LIB_CACHES_KB") · npm $(human_kb "$NPM_KB") · bun $(human_kb "$BUN_KB"))"
[[ "$(uname -s)" == "Linux"  ]] && \
  START_BANNER+=" (xdg $(human_kb "$XDG_KB") · npm $(human_kb "$NPM_KB") · bun $(human_kb "$BUN_KB") · cargo $(human_kb "$CARGO_KB"))"
notify "$START_BANNER"

# ── Phase 2: clean ────────────────────────────────────────────────────
clean_dir() {
  local label="$1" path="$2"
  if [[ ! -d "$path" ]]; then
    printf '  skip  %-18s (not present)\n' "$label"
    return
  fi
  local size
  size=$(du -sh "$path" 2>/dev/null | awk '{print $1}')
  if (( DRY_RUN )); then
    printf '  DRY   %-18s would clean %s (%s)\n' "$label" "$path" "$size"
  else
    printf '  clean %-18s %s (%s)\n' "$label" "$path" "$size"
    find "$path" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null || true
  fi
}

run_cmd() {
  local label="$1"; shift
  if (( DRY_RUN )); then
    printf '  DRY   %-18s would run: %s\n' "$label" "$*"
  else
    printf '  run   %-18s %s\n' "$label" "$*"
    if ! "$@" >/dev/null 2>&1; then
      printf '    warn: %s exited non-zero\n' "$label"
    fi
  fi
}

# Truncate (not delete) runaway *.log files over a size threshold in a
# safelist of log dirs. Truncation preserves the inode/fd so a running
# writer (e.g. a gateway daemon) keeps logging — a 4.1G gateway.err.log
# is the canonical offender this targets.
truncate_logs() {
  local threshold_mb=200 d f sz
  for d in "$HOME/.local/state" "$HOME/.openclaw/logs" "$HOME/Library/Logs"; do
    [[ -d "$d" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      sz=$(du -h "$f" 2>/dev/null | awk '{print $1}')
      if (( DRY_RUN )); then
        printf '  DRY   %-18s would truncate %s (%s)\n' "log-truncate" "$f" "$sz"
      else
        printf '  trunc %-18s %s (%s)\n' "log-truncate" "$f" "$sz"
        : > "$f" 2>/dev/null || true
      fi
    done < <(find "$d" -type f -name '*.log' -size "+${threshold_mb}M" 2>/dev/null)
  done
}

# Sweep regenerable BUILD output under ~/dev — .turbo / .next dirs and
# *.bun-build files — that have been untouched for >7 days. NEVER touches
# node_modules or .git. Active projects rebuild instantly; stale clones
# get reclaimed. This widens the historical "don't touch ~/dev" contract
# (deliberate, signed off) — node_modules remains sacrosanct.
sweep_build_caches() {
  [[ -d "$HOME/dev" ]] || return
  local age_days=7 target n=0
  while IFS= read -r target; do
    [[ -z "$target" ]] && continue
    if (( DRY_RUN )); then
      printf '  DRY   %-18s would rm %s\n' "build-cache" "$target"
    else
      rm -rf "$target" 2>/dev/null || true
    fi
    n=$((n + 1))
  done < <(
    find "$HOME/dev" \
      \( -type d -name node_modules -prune \) -o \
      \( -type d -name .git -prune \) -o \
      \( -type d \( -name .turbo -o -name .next \) -mtime "+${age_days}" -prune -print \) -o \
      \( -type f -name '.*.bun-build' -mtime "+${age_days}" -print \) \
      2>/dev/null
  )
  printf '  sweep %-18s %d stale build-cache target(s) (>%dd, dry=%d)\n' \
    "build-cache" "$n" "$age_days" "$DRY_RUN"
}

# Cursor/Electron renderer crash logs get dumped straight into $HOME as
# <ts>.Default.wXtYpZ.<uuid>.<pid>.<n>.log — ~80 accumulated in weeks.
# These are per-session crash dumps (not append logs): delete, don't
# truncate. Age-gated >7d so a fresh crash log under investigation stays.
sweep_stray_home_logs() {
  local age_days=7 f n=0
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if (( DRY_RUN )); then
      printf '  DRY   %-18s would rm %s\n' "home-stray-log" "$(basename "$f")"
    else
      rm -f "$f" 2>/dev/null || true
    fi
    n=$((n + 1))
  done < <(find "$HOME" -maxdepth 1 -type f -name '*.Default.w*.log' -mtime "+${age_days}" 2>/dev/null)
  printf '  sweep %-18s %d stray home-root log(s) (>%dd, dry=%d)\n' \
    "home-stray-log" "$n" "$age_days" "$DRY_RUN"
}

clean_dir "xdg-cache" "$HOME/.cache"
command -v npm    >/dev/null && run_cmd "npm-cache"   npm cache clean --force
command -v pnpm   >/dev/null && run_cmd "pnpm-prune"  pnpm store prune
command -v bun    >/dev/null && run_cmd "bun-cache"   bun pm cache rm
command -v dotnet >/dev/null && run_cmd "nuget-clear" dotnet nuget locals all --clear

# Cross-platform: runaway logs + stale ~/dev build output + stray $HOME logs.
truncate_logs
sweep_build_caches
sweep_stray_home_logs

if [[ "$(uname -s)" == "Darwin" ]]; then
  clean_dir "library-caches" "$HOME/Library/Caches"
  command -v brew >/dev/null && run_cmd "brew-cleanup" brew cleanup --prune=all
fi

if [[ "$(uname -s)" == "Linux" ]]; then
  command -v yarn  >/dev/null && run_cmd "yarn-clean"  yarn cache clean
  command -v cargo >/dev/null && [[ -d "$HOME/.cargo/registry/cache" ]] && \
    clean_dir "cargo-registry" "$HOME/.cargo/registry/cache"
fi

# ── Phase 3: report ──────────────────────────────────────────────────
END_FREE_KB=$(df -k "$HOME" | tail -1 | awk '{print $4}')
END_FREE_PCT=$(df -k "$HOME" | tail -1 | awk '{print $5}')
DELTA_KB=$((END_FREE_KB - START_FREE_KB))
DELTA_HUMAN=$(human_kb "$DELTA_KB")
# human_kb returns absolute formatting; sign the delta for the banner.
SIGN="+"; (( DELTA_KB < 0 )) && SIGN="-" && DELTA_HUMAN=$(human_kb $((-DELTA_KB)))

echo "  free at end:       $(human_kb "$END_FREE_KB") ($END_FREE_PCT used)"
echo "=== done. delta: ${SIGN}${DELTA_HUMAN} ==="

# Completion sentinel — flips the _on_exit trap from "FAILED" to silent and
# records a success heartbeat the next run's Phase-1 health check reads.
# Set BEFORE the radar so a slow `du` in bloat_radar can never trip the
# failure trap or lose the success record.
COMPLETED=1
date -Iseconds > "$HEARTBEAT" 2>/dev/null || true

# Scan adjacent-but-untouched dirs and populate BLOAT_WARN.
bloat_radar

END_BANNER="Weekly cleanup done"
[[ $DRY_RUN -eq 1 ]] && END_BANNER="Weekly cleanup DRY-RUN done"
END_BANNER+=" — freed ${SIGN}${DELTA_HUMAN} · disk now $(human_kb "$END_FREE_KB") free ($END_FREE_PCT used)"

# Dedicated, loud TTS for adjacent bloat — this is the early-warning the
# disk-fill incident lacked. Spoken separately so it isn't lost in the
# routine summary; the summary then follows with the radar list appended.
if [[ -n "$BLOAT_WARN" ]]; then
  echo "  BLOAT SUMMARY: $BLOAT_WARN"
  notify "Disk bloat warning — $BLOAT_WARN. Not auto-cleaned; needs your call."
  END_BANNER+=" · BLOAT: $BLOAT_WARN"
fi
notify "$END_BANNER"
