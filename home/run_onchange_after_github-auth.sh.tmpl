#!/usr/bin/env bash
# run_onchange_after_github-auth.sh — GitHub + GitKraken auth wiring, sourced
# from a 1Password-stored PAT (not an interactive `gh auth login`).
#
# Re-runs whenever this file's rendered content changes (run_onchange prefix), in
# the AFTER stage so Homebrew/pacman packages (gh, gk) and the global git identity
# are already in place.
#
# Chains the full auth pipeline:
#   1. Ensure the GitHub CLI (`gh`) is installed.
#   2. Read the PAT from 1Password ($OP_GH_ITEM) — source of truth is 1Password,
#      NOT an interactive gh device/web-flow login (that's what this replaces;
#      the old flow required a browser round-trip on every token rotation).
#   3. Stash the PAT in the OS keychain (macOS Keychain / Linux libsecret) —
#      dot_zshenv.tmpl exports it from there as GH_TOKEN/GITHUB_TOKEN. Once
#      GH_TOKEN is exported, `gh` uses it directly for every operation — no
#      separate `gh auth login` needed.
#   4. Wire global git credentials with BOTH helpers: `gh` first, native keychain
#      helper as fallback (the multi-valued chain pattern from configure-git-azure).
#   5. Sign in to the GitKraken CLI (`gk auth login`) and attach the GitHub token
#      as a provider (`gk provider add github -t <PAT>`).
#
# TTY GUARD (critical): mesh deploys run `chezmoi apply` non-interactively and
# force-reset this repo (see memory: "Mac is a deploy target"). `op read` needs
# an interactive unlock (Touch ID / app approval) the first time per session, so
# the script no-ops unless stdin is a real terminal and CI is unset.
#
# PREREQUISITES (one-time):
#   1. op (1Password CLI, Brewfile cask) + app integration:
#      1Password 8 > Settings > Developer > "Integrate with 1Password CLI".
#   2. A GitHub PAT stored in 1Password at $OP_GH_ITEM (default below; override
#      by exporting it before `chezmoi apply`).

set -uo pipefail

DOTFILES="{{ .chezmoi.workingTree }}"

# --- tiny logging helpers (ASCII only, no emojis) ---------------------------
info()    { printf '  ->  %s\n' "$*"; }
success() { printf '  OK  %s\n' "$*"; }
warn()    { printf 'WARN  %s\n' "$*"; }

# --- TTY guard --------------------------------------------------------------
if [[ ! -t 0 || -n "${CI:-}" ]]; then
	echo "github-auth: non-interactive shell — skipping (op needs an interactive unlock)."
	echo "github-auth: run 'chezmoi apply' (or this script) in a terminal to complete."
	exit 0
fi

{{ if eq .chezmoi.os "darwin" -}}
# --- macOS platform bindings ------------------------------------------------
ensure_gh() { brew list gh >/dev/null 2>&1 || brew install gh; }
keychain_store() {
	# -U updates in place if the item already exists.
	security add-generic-password -U -a "$USER" -s github-pat -w "$1" >/dev/null 2>&1
}
GIT_FALLBACK_HELPER="osxkeychain"
{{ else if eq .chezmoi.os "linux" -}}
# --- Arch / Linux platform bindings -----------------------------------------
ensure_gh() {
	command -v gh >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm github-cli
	# libsecret provides `secret-tool` + git-credential-libsecret (Arch ships the
	# git helper compiled in). Needed for both keychain storage and the git fallback.
	command -v secret-tool >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm libsecret
}
keychain_store() {
	if command -v secret-tool >/dev/null 2>&1; then
		printf '%s' "$1" | secret-tool store --label="github-pat" service github-pat account "$USER"
	else
		warn "secret-tool not found — token left unstored (no env export)."
		return 1
	fi
}
# Prefer libsecret; fall back to a 24h credential cache if the helper is absent.
if [[ -x /usr/lib/git-core/git-credential-libsecret ]]; then
	GIT_FALLBACK_HELPER="libsecret"
else
	GIT_FALLBACK_HELPER="cache --timeout=86400"
fi
{{ end -}}

# --- 1. ensure gh -----------------------------------------------------------
if ! ensure_gh; then
	warn "could not install gh — aborting auth setup."
	exit 0
fi

# --- 2. read the PAT from 1Password -----------------------------------------
# Override by exporting OP_GH_ITEM before `chezmoi apply`. Form: op://<vault>/<item>/<field>.
: "${OP_GH_ITEM:=op://Personal/GH_PAT/credential}"

command -v op >/dev/null 2>&1 || {
	warn "op (1Password CLI) not installed — run 'brew bundle' first. Skipping GitHub PAT wiring."
	exit 0
}
if ! op whoami >/dev/null 2>&1; then
	info "Signing in to the 1Password CLI (approve in the app / Touch ID)..."
	op signin >/dev/null 2>&1 || {
		warn "op signin failed — enable Settings > Developer > Integrate with 1Password CLI, then re-run."
		exit 0
	}
fi

TOKEN="$(op read "$OP_GH_ITEM" 2>/dev/null || true)"
if [[ -z "$TOKEN" ]]; then
	warn "Could not read $OP_GH_ITEM from 1Password."
	warn "Store a GitHub PAT there (scopes: repo,read:org,gist,read:packages), or set OP_GH_ITEM to your ref."
	exit 0
fi

# --- 3. store the PAT ---------------------------------------------------
if keychain_store "$TOKEN"; then
	success "PAT stored in OS keychain (service: github-pat)."
fi

# --- 4. git credentials: gh helper first, native keychain fallback ----------
# Unset-all then re-add so repeated runs converge to the same two-entry chain
# (same idempotent pattern as configure-git-azure).
git config --global --unset-all 'credential.https://github.com.helper' 2>/dev/null || true
git config --global --add 'credential.https://github.com.helper' '!gh auth git-credential'
git config --global --add 'credential.https://github.com.helper' "$GIT_FALLBACK_HELPER"
success "git credential chain set (gh -> $GIT_FALLBACK_HELPER) for github.com."

# Force HTTPS for every github.com clone (gk workspaces, `git clone`, `gh repo
# clone`). If a remote ever hands back an SSH URL, git rewrites it to HTTPS so
# the credential chain above applies and the keychain PAT is reused. Unset-all
# then re-add both SSH spellings so repeated runs converge (idempotent).
git config --global --unset-all 'url.https://github.com/.insteadof' 2>/dev/null || true
git config --global --add 'url.https://github.com/.insteadOf' 'git@github.com:'
git config --global --add 'url.https://github.com/.insteadOf' 'ssh://git@github.com/'
success "git url rewrite set (ssh -> https) for github.com."

# --- 5. GitKraken CLI -------------------------------------------------------
if command -v gk >/dev/null 2>&1; then
	if gk whoami >/dev/null 2>&1; then
		success "gk already signed in to the GitKraken platform."
	else
		info "Signing in to GitKraken (a browser window will open) ..."
		gk auth login || warn "gk auth login skipped — provider attach may fail until you sign in."
	fi
	# Attach the GitHub provider token via the shared helper (same code path as
	# the `gkauth` shell function, so bootstrap + manual re-attach never drift).
	. "$DOTFILES/scripts/gk-github-auth.sh"
	if gk_attach_github "$TOKEN"; then
		success "gk: GitHub provider token attached."
	else
		warn "gk provider add github failed — sign in to gk first, then re-run 'gkauth'."
	fi
else
	warn "gk (GitKraken CLI) not on PATH — skipping. Expected from the Brewfile cask 'gitkraken-cli'."
fi

echo "github-auth: done. Open a new shell to pick up GH_TOKEN/GITHUB_TOKEN."
