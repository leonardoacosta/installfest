# Environment and Secrets
.env
*.key
*.pem
*.crt

# Logs
*.log
logs/

# Cache and temporary files
*/cache/
*/tmp/
*.tmp
*.swp
*.swo
*~

# Python bytecode
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Backup files
*.bak
*.backup

# SSH keys
ssh-mesh/keys/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Terraform
infra/.secrets.env
infra/.tf-outputs.env
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# workspace: generated profile artifacts (regenerated by generate-profiles on chezmoi apply)
packages/workspace/profiles/*/env.sh
packages/workspace/profiles/*/claude/
packages/workspace/profiles/*/wrappers/
