# Environment and Secrets
.env
*.key
*.pem
*.crt

# Logs
*.log
logs/

# Cache and temporary files
*/cache/
*/tmp/
*.tmp
*.swp
*.swo
*~

# Python bytecode
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Backup files
*.bak
*.backup

# SSH keys
ssh-mesh/keys/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Terraform
infra/.secrets.env
infra/.tf-outputs.env
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# workspace: generated profile artifacts (regenerated by generate-profiles on chezmoi apply)
packages/workspace/profiles/*/env.sh
packages/workspace/profiles/*/wrappers/

# workspace: claude/ is the --add-dir target — mostly machine-local/generated, EXCEPT
# .claude/skills/ which is the committed org-scoped-skill channel (scope-skills-to-profiles).
# See if/packages/workspace/README.md § Bootstrap profile note + cc's
# openspec/changes/scope-skills-to-profiles/ for why this one subpath is carved out.
packages/workspace/profiles/*/claude/*
!packages/workspace/profiles/*/claude/.claude/
!packages/workspace/profiles/*/claude/.claude/skills/
!packages/workspace/profiles/*/claude/.claude/skills/**

# /apply per-session git worktrees + index (runtime state, never committed)
.worktrees/
.worktrees-index.json
.worktrees-index.json.lock

# /apply:all run state (locks, events.jsonl, active/last pointers — runtime, never committed)
docs/apply/
