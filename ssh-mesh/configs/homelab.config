# SSH Config for Homelab (homelab)
# Location: ~/.ssh/config

Host cloudpc
    HostName 100.83.148.5
    User leo
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ConnectTimeout 10

Host mac
    HostName macbook-pro.tail296462.ts.net
    User leonardoacosta
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ConnectTimeout 10
