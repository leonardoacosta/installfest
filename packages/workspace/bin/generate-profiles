#!/usr/bin/env bash
# generate-workspace-profiles.sh — emit per-org workspace profiles from projects.toml.
#
# Source of truth: home/projects.toml (the `category` field defines the org set).
# Output: ~/.config/workspace/<org>/ with the artifacts wsenv consumes:
#   env.sh        sourced for env vars (e.g. AZURE_CONFIG_DIR)
#   wrappers/     prepended to PATH (org command wrappers) — created empty for now
#   claude/       --add-dir target (org-only skills) — created empty for now
#
# Consumed by: wsenv (~/.claude/scripts/bin/wsenv), cmux-workspaces.sh (Phase 4).
# Triggered by: home/run_onchange_after_generate-workspace-profiles.sh.tmpl on chezmoi apply.
#
# Idempotent: writes into a tmp tree, then atomically swaps each org dir. Pruning:
# orgs no longer in the registry get their profile dir removed.
#
# Current scope (Phase 3, B&B env-only): only b-and-b/env.sh carries real content
# (AZURE_CONFIG_DIR=~/.azure-bbadmin — the wrong-identity fix). client/personal get
# empty env.sh stubs. Wrappers/skills/MCP/prompt are scaffolded empty for later phases.
set -euo pipefail

# Registry source of truth: IF's projects.toml (read in-place; chezmoi-ignored).
# Package lives at ~/dev/if/packages/workspace/bin/, registry at ~/dev/if/home/.
REGISTRY="${WSENV_REGISTRY:-${DOTFILES:-$HOME/dev/if}/home/projects.toml}"
[[ -f "$REGISTRY" ]] || REGISTRY="$HOME/dev/if/home/projects.toml"
PROFILE_ROOT="${WSENV_PROFILE_DIR:-$HOME/.config/workspace}"

[[ -f "$REGISTRY" ]] || { echo "generate-workspace-profiles: registry not found: $REGISTRY" >&2; exit 1; }

# Resolve a python3 with tomllib (stdlib only in 3.11+; ambient python3 may be older,
# e.g. macOS /usr/bin/python3 == 3.9). Probe known-good interpreters in order.
WS_PY=""
for _py in python3.14 python3.13 python3.12 python3.11 python3; do
  if command -v "$_py" >/dev/null 2>&1 && "$_py" -c 'import tomllib' 2>/dev/null; then
    WS_PY="$_py"; break
  fi
done
[[ -n "$WS_PY" ]] || { echo "generate-workspace-profiles: no python3 with tomllib (need >= 3.11)" >&2; exit 1; }

# Distinct org set from the registry.
ORGS=$("$WS_PY" - "$REGISTRY" <<'PY'
import sys, tomllib
d = tomllib.load(open(sys.argv[1], "rb"))
cats = sorted({p.get("category", "personal") for p in d.get("projects", [])})
print("\n".join(cats))
PY
)

# Per-org env content. Keyed by org slug. Add new exports here as phases land.
emit_env() {
  local org="$1"
  case "$org" in
    b-and-b)
      cat <<'EOF'
# Workspace env: b-and-b (generated — edit generate-workspace-profiles.sh, not here)
# Correct default Azure identity for Brown & Brown work (was globally civalent).
export AZURE_CONFIG_DIR="$HOME/.azure-bbadmin"

# Ensure the cloudpc SOCKS5 tunnel (127.0.0.1:1080) is up — Azure CAE bypass needs it.
# Idempotent + quiet: skip if :1080 already listening, else start the user unit.
# ALL output redirected — this file is sourced inside the eval'd `wsenv --activate`,
# so any chatter on stdout would corrupt the activation shell. b-and-b ONLY.
if ! command ss -tlnH 'sport = :1080' 2>/dev/null | command grep -q .; then
  systemctl --user start cloudpc-tunnel.service >/dev/null 2>&1 || true
fi
EOF
      ;;
    priceless)
      cat <<'EOF'
# Workspace env: priceless (generated)
# (no shared priceless env yet — per-repo .env still applies)
EOF
      ;;
    personal)
      cat <<'EOF'
# Workspace env: personal (generated)
# (no shared personal env yet)
EOF
      ;;
    *)
      echo "# Workspace env: $org (generated, empty)"
      ;;
  esac
}

# Build into a tmp root, then swap.
TMP_ROOT="$(mktemp -d "${TMPDIR:-/tmp}/wsprofiles.XXXXXX")"
trap 'rm -rf "$TMP_ROOT"' EXIT

while IFS= read -r org; do
  [[ -z "$org" ]] && continue
  d="$TMP_ROOT/$org"
  mkdir -p "$d/wrappers" "$d/claude"
  emit_env "$org" > "$d/env.sh"
done <<< "$ORGS"

mkdir -p "$PROFILE_ROOT"

# Contract validator (cc-owned, referenced by stable absolute path — same convention
# as the rest of ~/.claude/scripts/bin/*). Each org's STAGED profile is validated
# BEFORE it is promoted; promotion is the existing atomic swap below.
VALIDATE="$HOME/.claude/scripts/bin/workspace-profile-validate"

# Per-org outcome tally for the three-state aggregate exit (rules/TOOLING.md fan-out
# convention): 0 = all valid, 1 = all failed, 2 = partial.
ORGS_OK=0
ORGS_FAILED=0

# Atomic per-org swap + prune orgs no longer present.
#
# Integration choice: STAGE -> VALIDATE -> PROMOTE-ON-PASS. The generator already
# builds each org into "$TMP_ROOT/$org" and then atomically swaps it into place. We
# validate the STAGED tmp dir against the contract first, and only perform the swap
# when it passes. A failing org is left UN-promoted: its existing on-disk profile (if
# any) is untouched and no invalid profile is ever finalized — per-org isolation, one
# bad org never aborts the run. This fits the existing tmp-then-swap shape with no
# restore logic and no chance of a half-written profile persisting.
for org in $ORGS; do
  [[ -z "$org" ]] && continue
  src="$TMP_ROOT/$org"
  dst="$PROFILE_ROOT/$org"

  # Validate the staged profile before promoting it.
  if [[ -x "$VALIDATE" ]]; then
    if ! "$VALIDATE" "$src"; then
      echo "generate-profiles: contract validation FAILED for org '$org' -> NOT promoted (kept existing profile)" >&2
      ORGS_FAILED=$((ORGS_FAILED + 1))
      continue
    fi
  fi

  rm -rf "$dst.old" 2>/dev/null || true
  [[ -d "$dst" ]] && mv "$dst" "$dst.old"
  mv "$src" "$dst"
  rm -rf "$dst.old" 2>/dev/null || true
  ORGS_OK=$((ORGS_OK + 1))
done

# Populate per-org wrapper sets. These shadow native CLIs ONLY when the org's
# workspace is active (wsenv prepends <org>/wrappers/ to PATH). Phase 3.3 scope:
# the bbadmin+SOCKS-proxy `az` belongs to b-and-b — relocated here so the global
# default can become native (priceless) az with no wrapper/guard.
BBADMIN_AZ="$HOME/.local/bin/az"
if [[ -x "$BBADMIN_AZ" ]] && grep -q 'azure-bbadmin' "$BBADMIN_AZ" 2>/dev/null; then
  install -m 0755 "$BBADMIN_AZ" "$PROFILE_ROOT/b-and-b/wrappers/az"
  echo "installed b-and-b/wrappers/az (bbadmin + SOCKS proxy)"
fi

# Prune stale org dirs (present on disk but no longer in the registry).
if [[ -d "$PROFILE_ROOT" ]]; then
  for existing in "$PROFILE_ROOT"/*/; do
    [[ -d "$existing" ]] || continue
    name="$(basename "$existing")"
    if ! grep -qx "$name" <<< "$ORGS"; then
      rm -rf "$existing"
      echo "pruned stale workspace profile: $name"
    fi
  done
fi

echo "workspace profiles generated under $PROFILE_ROOT: $(echo $ORGS | tr '\n' ' ')"

# Three-state aggregate exit (rules/TOOLING.md fan-out convention) so a CI / chezmoi
# caller can distinguish "nothing worked" from "most worked, one org drifted":
#   0 = all orgs valid + promoted | 1 = all orgs failed | 2 = partial (some skipped).
echo "generate-profiles: promoted=$ORGS_OK failed=$ORGS_FAILED"
if [[ "$ORGS_FAILED" -eq 0 ]]; then
  exit 0
elif [[ "$ORGS_OK" -eq 0 ]]; then
  exit 1
else
  exit 2
fi
