#!/usr/bin/env bash
# generate-profiles — registry-driven scaffolder for committed workspace profiles.
#
# Source of truth: home/projects.toml (the `category` field defines the org set).
# Committed tree: packages/workspace/profiles/<org>/ — version-controlled, edited in
# place, and SYMLINKED into ~/.config/workspace/<org>/ by chezmoi
# (home/dot_config/workspace/symlink_<org>.tmpl). wsenv sources the symlinked path.
#
# This script no longer GENERATES content into ~/.config (that was the pre-rehome model,
# which clobbered the chezmoi symlink every apply — see cc rehome-workspace-profiles-to-repo
# task 1.7). It only SCAFFOLDS a skeleton for any org category in the registry that does
# not yet have a committed profile dir + its chezmoi symlink template. Existing profiles
# are never touched — their content (env.sh, plugin/, wrappers/, settings.json) is
# committed and hand-edited.
#
# Idempotent: an org whose profiles/<org>/ + symlink_<org>.tmpl already exist is a no-op.
# Newly-scaffolded files are left UNCOMMITTED for review + `git add` (never auto-committed).
(return 0 2>/dev/null) || set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/dev/if}"
REGISTRY="${WSENV_REGISTRY:-$DOTFILES/home/projects.toml}"
[[ -f "$REGISTRY" ]] || REGISTRY="$HOME/dev/if/home/projects.toml"
PROFILES_DIR="$DOTFILES/packages/workspace/profiles"
SYMLINK_TMPL_DIR="$DOTFILES/home/dot_config/workspace"

[[ -f "$REGISTRY" ]] || { echo "generate-profiles: registry not found: $REGISTRY" >&2; exit 1; }

# shellcheck source=../../../scripts/lib/registry.sh
source "$DOTFILES/scripts/lib/registry.sh"
WS_PY=$(registry_python) || exit 1

# Distinct org set from the registry.
ORGS=$("$WS_PY" - "$REGISTRY" <<'PY'
import sys, tomllib
d = tomllib.load(open(sys.argv[1], "rb"))
cats = sorted({p.get("category", "personal") for p in d.get("projects", [])})
print("\n".join(cats))
PY
)

mkdir -p "$PROFILES_DIR" "$SYMLINK_TMPL_DIR"

SCAFFOLDED=0
EXISTING=0
while IFS= read -r org; do
  [[ -z "$org" ]] && continue
  d="$PROFILES_DIR/$org"

  if [[ -d "$d" ]]; then
    EXISTING=$((EXISTING + 1))
  else
    # New org category — scaffold a portable skeleton. Content is a stub the user
    # fills in; the OS-coupled tunnel block belongs in a workspace-local overlay
    # (home/dot_config/workspace-local/<org>/env.local.sh.tmpl), NOT here.
    mkdir -p "$d/claude" "$d/wrappers"
    cat > "$d/env.sh" <<EOF
# Workspace env: $org (portable — committed, edit in place).
# Machine-coupled bits (tunnels, launchd/systemd) go in the chezmoi-rendered overlay
# ~/.config/workspace-local/$org/env.local.sh, sourced transitively below.

_ovl="\${XDG_CONFIG_HOME:-\$HOME/.config}/workspace-local/$org/env.local.sh"
[ -r "\$_ovl" ] && . "\$_ovl"
unset _ovl
EOF
    : > "$d/claude/.gitkeep"
    echo "scaffolded committed profile skeleton: profiles/$org/ (uncommitted — review + git add)"
    SCAFFOLDED=$((SCAFFOLDED + 1))
  fi

  # Ensure the chezmoi symlink template exists for this org.
  tmpl="$SYMLINK_TMPL_DIR/symlink_$org.tmpl"
  if [[ ! -f "$tmpl" ]]; then
    echo '{{ .chezmoi.sourceDir }}/../packages/workspace/profiles/'"$org" > "$tmpl"
    echo "scaffolded chezmoi symlink template: $(basename "$tmpl") (uncommitted — review + git add)"
    SCAFFOLDED=$((SCAFFOLDED + 1))
  fi
done <<< "$ORGS"

echo "generate-profiles: orgs=$(echo $ORGS | tr '\n' ' ')| existing=$EXISTING scaffolded=$SCAFFOLDED"
