#!/usr/bin/env bash
# Pre-commit hook: scan staged files for common secret patterns
# Prevents accidental commit of private keys, API keys, tokens, etc.

set -euo pipefail

PATTERNS=(
    '-----BEGIN .* PRIVATE KEY-----'
    'sk-[a-zA-Z0-9]{20,}'
    'AKIA[0-9A-Z]{16}'
    'b3BlbnNzaC1rZXktdjE'
)

# Build a combined regex from all patterns
COMBINED=""
for p in "${PATTERNS[@]}"; do
    if [ -z "$COMBINED" ]; then
        COMBINED="$p"
    else
        COMBINED="$COMBINED|$p"
    fi
done

# Get list of staged files (excluding deleted files and binary files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Scan staged content (not working tree) for secret patterns
FOUND=0
while IFS= read -r file; do
    # Skip binary files and this hook itself
    if [[ "$file" == *.png ]] || [[ "$file" == *.jpg ]] || [[ "$file" == *.ico ]] || \
       [[ "$file" == *.woff* ]] || [[ "$file" == *.ttf ]] || [[ "$file" == *.gz ]] || \
       [[ "$file" == ".githooks/pre-commit" ]] || [[ "$file" == docs/audit/* ]]; then
        continue
    fi

    # Check staged content (what will actually be committed)
    # -e guards against COMBINED starting with a dash (e.g. "-----BEGIN...")
    # being misread by grep as an option string instead of the pattern.
    MATCHES=$(git show ":$file" 2>/dev/null | grep -nEi -e "$COMBINED" 2>/dev/null || true)

    if [ -n "$MATCHES" ]; then
        if [ "$FOUND" -eq 0 ]; then
            echo ""
            echo "SECRET SCAN FAILED - potential secrets detected in staged files:"
            echo "================================================================"
        fi
        FOUND=1
        echo ""
        echo "  $file:"
        echo "$MATCHES" | while IFS= read -r line; do
            echo "    $line"
        done
    fi
done <<< "$STAGED_FILES"

if [ "$FOUND" -ne 0 ]; then
    echo ""
    echo "================================================================"
    echo "Commit blocked. Remove secrets before committing."
    echo "To bypass (emergency): git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
